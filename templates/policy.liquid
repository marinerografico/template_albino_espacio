{% comment %}
  Plantilla para políticas de Shopify: Privacidad, Condiciones, Envíos, Devoluciones.
  Mobile-first, misma estructura que page.liquid para consistencia.
{% endcomment %}
<article class="legal-page">
  <header class="legal-page-header">
    <h1 class="legal-page-title">{{ policy.title }}</h1>
  </header>
  <div class="legal-page-content page-content">
    {{ policy.body }}
  </div>
</article>
