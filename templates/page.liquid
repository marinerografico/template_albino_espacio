{% comment %}
  Plantilla por defecto para páginas (Aviso Legal, Política de Cookies, etc.).
  Usada cuando se selecciona "Página predeterminada".
{% endcomment %}
<article class="max-w-[720px] mx-auto px-6 py-16 md:py-24">
  <h1 class="font-display text-2xl md:text-3xl font-light tracking-tight text-stone-900 mb-8">
    {{ page.title }}
  </h1>
  <div class="page-content font-body font-light text-stone-900 leading-relaxed text-base [&_p]:mb-4 [&_h2]:mt-8 [&_h2]:mb-4 [&_h2]:text-lg [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_a]:border-b [&_a]:border-stone-900 [&_a]:hover:text-[#B56B80]">
    {{ page.content }}
  </div>
</article>
