{% comment %}
  Header mínimo para página Mirada (NFC). Logo Albino para volver.
{% endcomment %}
<header id="main-header" class="fixed top-0 left-0 w-full z-40 h-16 flex items-center justify-center px-6" aria-label="Navegación">
  <a href="{{ routes.root_url }}">
    {% if settings.logo != blank %}
      <img src="{{ settings.logo | image_url: width: 240 }}" alt="Logotipo de Albino, vino de Tierra de Barros" class="w-[100px] md:w-[120px] h-auto object-contain" width="120" height="48">
    {% else %}
      <img data-bind-src="assets.logo" alt="Logotipo de Albino, vino de Tierra de Barros" class="w-[100px] md:w-[120px] h-auto object-contain" width="120" height="48">
    {% endif %}
  </a>
</header>
