<footer class="w-full pt-12 pb-6 md:pt-24 reveal" role="contentinfo">
  <div class="w-full max-w-[1200px] mx-auto px-8 md:px-16 lg:px-24">
    {% if settings.logo != blank %}
      <img src="{{ settings.logo | image_url: width: 800 }}" alt="Logotipo de Albino, vino tinto dulce de Tierra de Barros" class="w-full max-w-[400px] h-auto object-contain mb-8 md:mb-12" width="400" height="120">
    {% else %}
      <img data-bind-src="assets.logo" alt="Logotipo de Albino, vino tinto dulce de Tierra de Barros" class="w-full max-w-[400px] h-auto object-contain mb-8 md:mb-12" width="400" height="120">
    {% endif %}
    <div class="space-y-6 border-t border-[#e5e4e1] pt-6 text-stone-900">
      <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-4">
        <p class="font-geist-mono text-[10px] md:text-xs font-light tracking-[0.2em] uppercase">
          © {{ 'now' | date: '%Y' }} Albino.
        </p>
        <nav class="flex flex-wrap gap-x-6 gap-y-1" aria-label="Navegación">
          <a href="{{ routes.root_url }}blogs/journal" class="font-geist-mono text-[10px] md:text-xs uppercase font-light tracking-[0.2em] transition-colors hover:text-[#B56B80] text-stone-900">Journal</a>
          <a href="{{ routes.root_url }}pages/mirada" class="font-geist-mono text-[10px] md:text-xs uppercase font-light tracking-[0.2em] transition-colors hover:text-[#B56B80] text-stone-900">Mirada</a>
          {% if settings.footer_instagram_url != blank %}
            <a href="{{ settings.footer_instagram_url }}" target="_blank" rel="noopener noreferrer" class="font-geist-mono text-[10px] md:text-xs uppercase font-light tracking-[0.2em] transition-colors hover:text-[#B56B80] text-stone-900">Instagram</a>
          {% else %}
            <a href="https://instagram.com" class="font-geist-mono text-[10px] md:text-xs uppercase font-light tracking-[0.2em] transition-colors hover:text-[#B56B80] text-stone-900" rel="noopener noreferrer" target="_blank">Instagram</a>
          {% endif %}
        </nav>
      </div>
      <nav class="flex flex-wrap gap-x-6 gap-y-1 font-geist-mono text-[10px] md:text-xs uppercase font-light tracking-[0.2em]" aria-label="Información legal">
        <a href="{{ routes.root_url }}pages/aviso-legal" class="transition-colors hover:text-[#B56B80] text-stone-900">Aviso Legal</a>
        <a href="{{ routes.root_url }}policies/privacy-policy" class="transition-colors hover:text-[#B56B80] text-stone-900">Política de Privacidad</a>
        <a href="{{ routes.root_url }}pages/politica-cookies" class="transition-colors hover:text-[#B56B80] text-stone-900">Política de Cookies</a>
        <a href="{{ routes.root_url }}policies/terms-of-service" class="transition-colors hover:text-[#B56B80] text-stone-900">Condiciones de Compra</a>
        <a href="{{ routes.root_url }}policies/shipping-policy" class="transition-colors hover:text-[#B56B80] text-stone-900">Envíos</a>
        <a href="{{ routes.root_url }}policies/refund-policy" class="transition-colors hover:text-[#B56B80] text-stone-900">Devoluciones</a>
      </nav>
    </div>
  </div>
</footer>
