      "publisher": { "@id": "{{ shop.url }}/#organization" },
      "mainEntityOfPage": "{{ shop.url }}/pages/journal",
      "inLanguage": "{{ request.locale.iso_code | default: 'es' }}"
    },
    {
      "@type": ["Article","BlogPosting"],
      "@id": "{{ shop.url }}/pages/journal#vino-objeto-cultural",
      "headline": "El vino como objeto cultural",
      "description": "Cómo el vino Albino funciona también como objeto cultural que fija memoria, territorio y diseño contemporáneo.",
      "articleSection": "Cultura",
      "author": { "@type": "Organization", "name": "Albino" },
      "publisher": { "@id": "{{ shop.url }}/#organization" },
      "mainEntityOfPage": "{{ shop.url }}/pages/journal",
      "inLanguage": "{{ request.locale.iso_code | default: 'es' }}"
    },
    {
      "@type": ["Article","BlogPosting"],
      "@id": "{{ shop.url }}/pages/journal#la-mirada",
      "headline": "La mirada",
      "description": "El concepto de Albino: equilibrio, silencio y lo esencial aplicados a un vino tinto dulce de Tierra de Barros, Extremadura.",
      "articleSection": "Mirada",
      "author": { "@type": "Organization", "name": "Albino" },
      "publisher": { "@id": "{{ shop.url }}/#organization" },
      "mainEntityOfPage": "{{ shop.url }}/pages/journal",
      "inLanguage": "{{ request.locale.iso_code | default: 'es' }}"
    }
  ]
}
</script>

