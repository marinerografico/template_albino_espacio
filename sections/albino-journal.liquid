{% comment %}
  Journal — índice editorial. Grid de tarjetas (imagen + preview) que enlazan a páginas de artículo.
  Estilo tipo Savor: maquetación visual de imágenes con texto a modo preview.
{% endcomment %}

<section class="px-6 pt-32 pb-24 md:pt-40 md:pb-40 lg:pt-48 lg:pb-48 bg-[#F5F4F1]" aria-labelledby="journal-title">
  <div class="max-w-[1200px] mx-auto">
    <header class="reveal-editorial mb-16 md:mb-20">
      <p class="font-geist-mono text-[11px] md:text-xs uppercase tracking-[0.25em] text-stone-500 mb-4">
        Journal · Territorio · Cultura
      </p>
      <h1 id="journal-title" class="espacio-title font-display heading-page text-stone-900 mb-6">
        Journal
      </h1>
      <p class="max-w-[620px] text-sm md:text-base font-body font-light text-stone-700 leading-relaxed">
        {{ section.settings.intro | default: 'Albino es un vino tinto dulce joven de edición limitada elaborado en Tierra de Barros, Extremadura. Este cuaderno recoge notas sobre el territorio, la cultura del vino y la mirada que sostiene el proyecto.' }}
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10 lg:gap-12">
      {% for block in section.blocks %}
        {% assign card_url = block.settings.article_url | default: '#' %}
        <article class="reveal-editorial group" aria-labelledby="journal-card-{{ block.id }}" {{ block.shopify_attributes }}>
          <a href="{{ card_url }}" class="block text-stone-900 focus:outline-none focus-visible:ring-2 focus-visible:ring-stone-400 focus-visible:ring-offset-2 focus-visible:ring-offset-[#F5F4F1]">
            <figure class="overflow-hidden aspect-[4/3] mb-5 bg-stone-200">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.image_alt | default: block.settings.title | escape }}"
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]"
                  width="600"
                  height="450"
                >
              {% else %}
                <img
                  src="{{ 'journal-placeholder.jpg' | asset_url }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]"
                  width="600"
                  height="450"
                >
              {% endif %}
            </figure>
            <div>
              {% if block.settings.kicker != blank %}
                <p class="font-geist-mono text-[11px] md:text-xs uppercase tracking-[0.25em] text-stone-500 mb-2">
                  {{ block.settings.kicker }}
                </p>
              {% endif %}
              <h2 id="journal-card-{{ block.id }}" class="espacio-title font-display text-lg md:text-xl tracking-tight text-stone-900 mb-3 group-hover:text-stone-700 transition-colors">
                {{ block.settings.title }}
              </h2>
              {% if block.settings.intro != blank %}
                <p class="text-sm font-body font-light text-stone-600 leading-relaxed mb-4">
                  {{ block.settings.intro | strip_html | truncate: 140 }}
                </p>
              {% endif %}
              <span class="font-geist-mono text-[11px] md:text-xs uppercase tracking-[0.2em] text-stone-500 border-b border-stone-400 group-hover:border-stone-900 pb-0.5 transition-colors">
                {{ section.settings.read_more_label | default: 'Leer artículo' }}
              </span>
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": "{{ shop.url }}/pages/journal#blog",
      "name": "Journal Albino",
      "url": "{{ shop.url }}/pages/journal",
      "description": "Cuaderno editorial de Albino sobre vino tinto dulce, Tierra de Barros (Extremadura) y cultura del territorio."
    }
    {% for block in section.blocks %}
    {% if block.settings.article_url != blank %}
    ,{
      "@type": ["Article","BlogPosting"],
      "@id": "{{ shop.url }}{{ block.settings.article_url }}#article",
      "headline": {{ block.settings.title | json }},
      "description": {{ block.settings.intro | default: '' | truncate: 200 | json }},
      "author": { "@type": "Organization", "name": "Albino" },
      "publisher": { "@id": "{{ shop.url }}/#organization" },
      "url": "{{ shop.url }}{{ block.settings.article_url }}",
      "inLanguage": "{{ request.locale.iso_code | default: 'es' }}"
    }
    {% endif %}
    {% endfor %}
  ]
}
</script>

{% schema %}
{
  "name": "Albino Journal",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Cabecera"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Texto de introducción",
      "default": "Albino es un vino tinto dulce joven de edición limitada elaborado en Tierra de Barros, Extremadura. Este cuaderno recoge notas sobre el territorio, la cultura del vino y la mirada que sostiene el proyecto."
    },
    {
      "type": "text",
      "id": "read_more_label",
      "label": "Texto del enlace en cada tarjeta",
      "default": "Leer artículo"
    }
  ],
  "blocks": [
    {
      "type": "entry",
      "name": "Artículo (tarjeta)",
      "settings": [
        {
          "type": "url",
          "id": "article_url",
          "label": "Enlace al artículo",
          "info": "Página con plantilla 'journal-article' donde está el texto completo."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Tierra de Barros"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker / línea superior",
          "default": "Suelo · Origen · Extremadura"
        },
        {
          "type": "textarea",
          "id": "intro",
          "label": "Extracto (preview en la tarjeta)",
          "default": "Tierra de Barros es una comarca del sur de Extremadura donde la arcilla aparece a simple vista."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen de la tarjeta"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Alt de la imagen",
          "default": "Viñedos en Tierra de Barros"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Albino Journal",
      "blocks": [
        { "type": "entry", "settings": { "title": "Tierra de Barros", "kicker": "Suelo · Origen · Extremadura" } },
        { "type": "entry", "settings": { "title": "La vendimia", "kicker": "Manos · Ritmo · Cosecha" } },
        { "type": "entry", "settings": { "title": "El vino como objeto cultural", "kicker": "Cultura · Memoria · Territorio" } },
        { "type": "entry", "settings": { "title": "La mirada", "kicker": "Equilibrio · Silencio · Esencial" } }
      ]
    }
  ]
}
{% endschema %}
