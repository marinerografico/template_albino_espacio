      "publisher": { "@id": "{{ shop.url }}/#organization" },
      "mainEntityOfPage": "{{ shop.url }}/pages/journal",
      "inLanguage": "{{ request.locale.iso_code | default: 'es' }}"
    },
    {
      "@type": ["Article","BlogPosting"],
      "@id": "{{ shop.url }}/pages/journal#la-vendimia",
      "headline": "La vendimia",
      "description": "La vendimia en Tierra de Barros como momento de trabajo manual, lectura del paisaje y origen del vino tinto dulce Albino.",
      "articleSection": "Cosecha",
