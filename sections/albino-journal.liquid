{% comment %}
  Sección editorial "Journal" para Albino.
  Página pensada como cuaderno / revista, no como blog clásico.
{% endcomment %}

<section class="px-6 pt-32 pb-24 md:pt-40 md:pb-40 lg:pt-48 lg:pb-48 bg-[#F5F4F1]" aria-labelledby="journal-title">
  <div class="max-w-[1040px] mx-auto">
    <header class="reveal-editorial">
      <p class="font-geist-mono text-[11px] md:text-xs uppercase tracking-[0.25em] text-stone-500 mb-4">
        Journal · Territorio · Cultura
      </p>
      <h1 id="journal-title" class="espacio-title font-display heading-page text-stone-900 mb-6">
        Journal
      </h1>
      <p class="max-w-[620px] text-sm md:text-base font-body font-light text-stone-700 leading-relaxed">
        Albino es un vino tinto dulce joven de edición limitada elaborado en Tierra de Barros, Extremadura.
        Este cuaderno recoge notas sobre el territorio, la cultura del vino y la mirada que sostiene el proyecto.
      </p>
    </header>

    <div class="mt-16 md:mt-20 space-y-16 md:space-y-20">
      {% for block in section.blocks %}
        <article class="reveal-editorial border-t border-[#e5e4e1] pt-10 md:pt-12" aria-labelledby="journal-article-{{ block.id }}" {{ block.shopify_attributes }}>
          <div class="grid md:grid-cols-[minmax(0,3fr)_minmax(0,2fr)] gap-10 md:gap-16 items-start">
            <div>
              <h2 id="journal-article-{{ block.id }}" class="espacio-title font-display text-xl md:text-2xl tracking-tight text-stone-900 mb-4">
                {{ block.settings.title }}
              </h2>
              {% if block.settings.kicker != blank %}
                <p class="font-geist-mono text-[11px] md:text-xs uppercase tracking-[0.25em] text-stone-500 mb-5">
                  {{ block.settings.kicker }}
                </p>
              {% endif %}
              {% if block.settings.intro != blank %}
                <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800 mb-4">
                  {{ block.settings.intro }}
                </p>
              {% endif %}
              {% if block.settings.body_1 != blank %}
                <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800 mb-4">
                  {{ block.settings.body_1 }}
                </p>
              {% endif %}
              {% if block.settings.body_2 != blank %}
                <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800 mb-4">
                  {{ block.settings.body_2 }}
                </p>
              {% endif %}
              {% if block.settings.body_3 != blank %}
                <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800">
                  {{ block.settings.body_3 }}
                </p>
              {% endif %}

              {% if block.settings.show_geo_context %}
                <section class="mt-8 pt-6 border-t border-[#e5e4e1]">
                  <h3 class="text-sm md:text-base font-geist-mono uppercase tracking-[0.18em] text-stone-500 mb-3">
                    {{ block.settings.geo_title }}
                  </h3>
                  {% if block.settings.geo_p1 != blank %}
                    <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800 mb-3">
                      {{ block.settings.geo_p1 }}
                    </p>
                  {% endif %}
                  {% if block.settings.geo_p2 != blank %}
                    <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800">
                      {{ block.settings.geo_p2 }}
                    </p>
                  {% endif %}
                </section>
              {% endif %}
            </div>
            <figure class="md:justify-self-end">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.image_alt | default: block.settings.title | escape }}"
                  loading="lazy"
                  class="w-full h-auto object-cover aspect-[4/3]"
                  width="800"
                  height="600"
                >
              {% else %}
                <img
                  src="{{ 'journal-placeholder.jpg' | asset_url }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  class="w-full h-auto object-cover aspect-[4/3]"
                  width="800"
                  height="600"
                >
              {% endif %}
              {% if block.settings.caption != blank %}
                <figcaption class="mt-3 text-[11px] md:text-xs font-geist-mono uppercase tracking-[0.18em] text-stone-500">
                  {{ block.settings.caption }}
                </figcaption>
              {% endif %}
            </figure>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{%- comment -%}
  JSON-LD específico del Journal:
  Describe el conjunto como Blog y cada entrada como BlogPosting/Article
  para mejorar SEO y GEO.
{%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": "{{ shop.url }}/pages/journal#blog",
      "name": "Journal Albino",
      "url": "{{ shop.url }}/pages/journal",
      "description": "Cuaderno editorial de Albino sobre vino tinto dulce, Tierra de Barros (Extremadura) y cultura del territorio."
    },
    {% for block in section.blocks %}
    ,{
      "@type": ["Article","BlogPosting"],
      "@id": "{{ shop.url }}/pages/journal#{{ block.id }}",
      "headline": {{ block.settings.title | json }},
      "description": {{ block.settings.intro | default: block.settings.body_1 | truncate: 200 | json }},
      "articleSection": {{ block.settings.section_label | default: 'Journal' | json }},
      "author": { "@type": "Organization", "name": "Albino" },
      "publisher": { "@id": "{{ shop.url }}/#organization" },
      "mainEntityOfPage": "{{ shop.url }}/pages/journal",
      "inLanguage": "{{ request.locale.iso_code | default: 'es' }}"
    }
    {% endfor %}
  ]
}
</script>

{% schema %}
{
  "name": "Albino Journal",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Journal"
    }
  ],
  "blocks": [
    {
      "type": "entry",
      "name": "Artículo",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Tierra de Barros"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker / línea superior",
          "default": "Suelo · Origen · Extremadura"
        },
        {
          "type": "textarea",
          "id": "intro",
          "label": "Introducción",
          "default": "Tierra de Barros es una comarca del sur de Extremadura donde la arcilla aparece a simple vista. El suelo es de un rojo denso, casi terroso, que retiene el agua y obliga a las raíces a profundizar."
        },
        {
          "type": "textarea",
          "id": "body_1",
          "label": "Cuerpo — párrafo 1",
          "default": "Albino se elabora en este paisaje. El vino tinto dulce joven que proponemos no se entiende sin este suelo, sin la mezcla de calores extremos, inviernos fríos y ese horizonte de viñedo bajo que dibuja la comarca."
        },
        {
          "type": "textarea",
          "id": "body_2",
          "label": "Cuerpo — párrafo 2",
          "default": "Hablar de Albino es, en gran parte, hablar de Tierra de Barros y de cómo la tradición agrícola de Extremadura sigue viva en cada viñedo."
        },
        {
          "type": "textarea",
          "id": "body_3",
          "label": "Cuerpo — párrafo 3",
          "default": "."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Alt de la imagen",
          "default": "Viñedos en Tierra de Barros sobre suelo rojo arcilloso"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Pie de foto",
          "default": "Suelo arcilloso rojo en Tierra de Barros, Extremadura."
        },
        {
          "type": "text",
          "id": "section_label",
          "label": "Etiqueta de sección (schema.org)",
          "default": "Territorio"
        },
        {
          "type": "checkbox",
          "id": "show_geo_context",
          "label": "Mostrar bloque 'Sobre Albino'",
          "default": true
        },
        {
          "type": "text",
          "id": "geo_title",
          "label": "Título bloque GEO",
          "default": "Sobre Albino"
        },
        {
          "type": "textarea",
          "id": "geo_p1",
          "label": "GEO — párrafo 1",
          "default": "Albino es un vino tinto dulce joven producido en Tierra de Barros, Extremadura. El proyecto nace de una tradición familiar vinculada al cultivo de la vid y propone una mirada contemporánea sobre el vino y el territorio."
        },
        {
          "type": "textarea",
          "id": "geo_p2",
          "label": "GEO — párrafo 2",
          "default": "La primera edición de Albino procede de viñedos situados en la región vitivinícola de Tierra de Barros, conocida por sus suelos arcillosos y su larga tradición agrícola."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Albino Journal",
      "blocks": [
        {
          "type": "entry",
          "settings": {
            "title": "Tierra de Barros",
            "kicker": "Suelo · Origen · Extremadura",
            "section_label": "Territorio"
          }
        },
        {
          "type": "entry",
          "settings": {
            "title": "La vendimia",
            "kicker": "Manos · Ritmo · Cosecha",
            "intro": "La vendimia en Tierra de Barros sigue siendo, en gran medida, un trabajo manual. No es solo cortar racimos: es leer el viñedo cada día y decidir cuándo entrar.",
            "body_1": "En Albino entendemos la vendimia como un momento de síntesis entre territorio, clima y manos. El vino tinto dulce joven que proponemos nace de esa decisión de cosechar en el punto justo.",
            "section_label": "Cosecha"
          }
        },
        {
          "type": "entry",
          "settings": {
            "title": "El vino como objeto cultural",
            "kicker": "Cultura · Memoria · Territorio",
            "intro": "Un vino no es solo una bebida. Es una forma de fijar en el tiempo una cosecha concreta y una manera de entender el trabajo agrícola.",
            "body_1": "Albino quiere situarse en ese cruce: vino tinto dulce joven que se bebe, pero también objeto cultural que habla de Tierra de Barros y de la tradición vitivinícola de Extremadura.",
            "section_label": "Cultura"
          }
        },
        {
          "type": "entry",
          "settings": {
            "title": "La mirada",
            "kicker": "Equilibrio · Silencio · Esencial",
            "intro": "Albino busca un equilibrio entre dulzor y frescura, entre la materia de Tierra de Barros y una forma de presentarla contenida, casi silenciosa.",
            "body_1": "La estética minimalista de la marca deja espacio al vino y a la conversación que lo rodea. Menos elementos, más atención a lo esencial.",
            "section_label": "Mirada"
          }
        }
      ]
    }
  ]
}
{% endschema %}

