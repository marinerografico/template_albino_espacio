{% comment %}
  Página Origen (antes Nosotros). Estructura simplificada:
  ORIGEN — TIERRA — ESFUERZO — Aquí empieza el vino — Imagen + CTA
{% endcomment %}
{% capture newline %}
{% endcapture %}

<!-- 1. ORIGEN -->
<section class="min-h-[100vh] flex items-start justify-start px-8 md:px-16 pt-40 md:pt-52 pb-24 bg-[#f5f2ed]">
  <div class="text-left max-w-[90%] md:max-w-[480px]">
    <h1 class="espacio-title font-display heading-page reveal text-stone-900 leading-[1.15]">
      {{ section.settings.origen_title }}
    </h1>
  </div>
</section>

<!-- Separador -->
<section class="py-16 md:py-24 px-8 md:px-16 bg-[#f5f2ed]">
  <p class="text-left font-geist-mono text-stone-400 text-[10px] tracking-[0.2em]">—</p>
</section>

<!-- 2. TIERRA -->
<section class="relative w-full min-h-[60vh] md:min-h-[80vh] overflow-hidden reveal">
  <div class="absolute inset-0 bg-stone-800">
    {% if section.settings.tierra_video_url != blank %}
      <video class="w-full h-full object-cover" autoplay muted loop playsinline>
        <source src="{{ section.settings.tierra_video_url | escape }}" type="video/mp4">
      </video>
    {% elsif section.settings.tierra_image != blank %}
      <img src="{{ section.settings.tierra_image | image_url: width: 1920 }}" class="w-full h-full object-cover" alt="Tierra de Barros" width="1920" height="1080" loading="lazy">
    {% endif %}
  </div>
  <div class="absolute inset-0 bg-[#B55239]/20 mix-blend-multiply pointer-events-none"></div>
  <div class="absolute inset-0 z-10 flex items-center justify-center px-8 md:px-16">
    <div class="w-full max-w-[560px] text-left">
      <h2 class="espacio-title font-display heading-page reveal text-[#F5F4F1] mb-4">
        {{ section.settings.tierra_title }}
      </h2>
      <p class="font-db-serif italic text-[#F5F4F1] text-[14px] md:text-base lowercase mb-10" style="letter-spacing: 0;">
        {{ section.settings.tierra_subtitle }}
      </p>
      <div class="space-y-4 text-[#F5F4F1]">
        {% assign tierra_items = section.settings.tierra_lines | split: newline %}
        {% for line in tierra_items %}
          {% if line != blank %}
            <p class="font-display uppercase text-[12px] md:text-[14px] leading-tight" style="margin-left: {{ forloop.index0 | times: 24 }}px; letter-spacing: 3px;">{{ line | strip }}</p>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- Separador -->
<section class="py-16 md:py-24 px-8 md:px-16 bg-[#f5f2ed]">
  <p class="text-left font-geist-mono text-stone-400 text-[10px] tracking-[0.2em]">—</p>
</section>

<!-- 3. ESFUERZO -->
<section class="min-h-[80vh] flex items-end justify-end px-8 md:px-16 pb-40 md:pb-52 bg-[#f5f2ed]">
  <div class="w-full max-w-[480px] text-right">
    <h2 class="espacio-title font-display heading-page reveal text-stone-900 mb-6">
      {{ section.settings.esfuerzo_title }}
    </h2>
    <div class="space-y-4 text-stone-900">
      {% assign esfuerzo_items = section.settings.esfuerzo_text | split: newline %}
      {% for line in esfuerzo_items %}
        {% if line != blank %}
          <p class="font-db-serif italic text-[14px] md:text-base lowercase leading-relaxed" style="letter-spacing: 0;">{{ line | strip }}</p>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- Separador -->
<section class="py-16 md:py-24 px-8 md:px-16 bg-[#f5f2ed]">
  <p class="text-right font-geist-mono text-stone-400 text-[10px] tracking-[0.2em]">—</p>
</section>

<!-- 4. Aquí empieza el vino -->
<section class="min-h-[100vh] flex flex-col items-center justify-center px-8 md:px-16 py-24 md:py-32 bg-[#f5f2ed]">
  <div class="reveal flex flex-col items-center text-center max-w-[560px]">
    <p class="font-db-serif italic text-stone-900 mb-16 text-xl md:text-2xl lowercase leading-relaxed" style="letter-spacing: 0;">
      {{ section.settings.cierre_text }}
    </p>
    {% if section.settings.cta_image != blank %}
      <img src="{{ section.settings.cta_image | image_url: width: 800 }}" alt="{{ section.settings.cta_image_alt | escape }}" class="w-full max-w-[340px] md:max-w-[380px] h-auto object-contain mix-blend-multiply opacity-90 filter contrast-110 mb-10">
    {% endif %}
    {% if section.settings.cta_url != blank and section.settings.cta_label != blank %}
      <a href="{{ section.settings.cta_url }}" class="inline-block uppercase hover:text-[#111111] transition-colors duration-500 ease-out text-xs md:text-sm font-light font-geist-mono text-[#6A6A6A] border-b border-[#a0a09e] hover:border-[#111111] pb-1">
        {{ section.settings.cta_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Origen",
  "settings": [
    {
      "type": "header",
      "content": "1 · Origen"
    },
    {
      "type": "text",
      "id": "origen_title",
      "label": "Título",
      "default": "ORIGEN"
    },
    {
      "type": "header",
      "content": "2 · Tierra"
    },
    {
      "type": "text",
      "id": "tierra_video_url",
      "label": "Vídeo de fondo (MP4)",
      "info": "Sube el MP4 a Content → Files y pega la URL."
    },
    {
      "type": "image_picker",
      "id": "tierra_image",
      "label": "Imagen de fondo (si no hay vídeo)"
    },
    {
      "type": "text",
      "id": "tierra_title",
      "label": "Título",
      "default": "TIERRA"
    },
    {
      "type": "text",
      "id": "tierra_subtitle",
      "label": "Subtítulo",
      "default": "Tierra de Barros, Extremadura"
    },
    {
      "type": "textarea",
      "id": "tierra_lines",
      "label": "Líneas (una por línea)",
      "default": "Arcilla roja.\nClima seco.\nUn paisaje abierto."
    },
    {
      "type": "header",
      "content": "3 · Esfuerzo"
    },
    {
      "type": "text",
      "id": "esfuerzo_title",
      "label": "Título",
      "default": "ESFUERZO"
    },
    {
      "type": "textarea",
      "id": "esfuerzo_text",
      "label": "Texto (multilínea)",
      "default": "Un trabajo que se repite cada año.\nSiempre afinándose."
    },
    {
      "type": "header",
      "content": "4 · Cierre e imagen"
    },
    {
      "type": "text",
      "id": "cierre_text",
      "label": "Texto de cierre",
      "default": "Aquí empieza el vino."
    },
    {
      "type": "image_picker",
      "id": "cta_image",
      "label": "Imagen (botella Albino)"
    },
    {
      "type": "text",
      "id": "cta_image_alt",
      "label": "Alt imagen",
      "default": "Botella Albino"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del CTA",
      "default": "Explorar la mirada"
    }
  ],
  "presets": [
    {
      "name": "Origen",
      "settings": {}
    }
  ]
}
{% endschema %}
