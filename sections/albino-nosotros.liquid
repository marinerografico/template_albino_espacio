{% comment %} Sección página Nosotros: versión narrativa con bloques Tierra / Manos / Mirada / Equilibrio / Lo esencial. {% endcomment %}

<!-- 1. ORIGEN (silencio) -->
<section class="min-h-[120vh] flex items-center justify-center px-6 pt-32">
  <div class="text-center">
    <h1 class="espacio-title font-display heading-page reveal text-stone-900">
      <span class="origen-hero-line">{{ section.settings.origen_title }}</span>
    </h1>
  </div>
</section>

<!-- 2. TIERRA (materia) -->
<section class="min-h-[120vh] relative overflow-hidden">
  <div class="absolute inset-0">
    {% if section.settings.tierra_video_url != blank %}
      <video class="w-full h-full object-cover" autoplay muted loop playsinline>
        <source src="{{ section.settings.tierra_video_url | escape }}" type="video/mp4">
      </video>
    {% elsif section.settings.tierra_image != blank %}
      <img src="{{ section.settings.tierra_image | image_url: width: 1600 }}" alt="{{ section.settings.tierra_image_alt | escape }}" class="w-full h-full object-cover">
    {% endif %}
    <div class="absolute inset-0 bg-[#B55239]/20 mix-blend-multiply pointer-events-none"></div>
  </div>
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="reveal px-6 md:px-16 lg:px-24 max-w-[520px] text-center relative z-10">
      <h2 class="espacio-title font-display heading-page reveal text-[#F5F4F1] mb-3">
        <span class="origen-hero-line" data-full-text="{{ section.settings.tierra_title }}">{{ section.settings.tierra_title }}</span>
      </h2>
      <p class="font-geist-mono text-[11px] md:text-xs uppercase tracking-[0.25em] text-[#F5F4F1]">
        {{ section.settings.tierra_subtitle }}
      </p>
    </div>
  </div>
</section>

<!-- 3. MANOS (cuerpo / esfuerzo) -->
<section class="min-h-[140vh] flex items-center justify-center px-6 md:px-12 lg:px-24">
  <div class="w-full max-w-[960px] mx-auto grid md:grid-cols-2 gap-16 items-center">
    <div class="reveal flex justify-center">
      {% if section.settings.manos_video_url != blank %}
        <video class="w-full max-w-[420px] aspect-[4/5] object-cover filter grayscale-[25%] contrast-110" autoplay muted loop playsinline>
          <source src="{{ section.settings.manos_video_url | escape }}" type="video/mp4">
        </video>
      {% elsif section.settings.manos_image != blank %}
        <img src="{{ section.settings.manos_image | image_url: width: 800 }}" alt="{{ section.settings.manos_image_alt | escape }}" class="w-full max-w-[420px] aspect-[4/5] object-cover filter grayscale-[25%] contrast-110">
      {% endif %}
    </div>
    <div class="reveal md:text-left text-center">
      <h2 class="espacio-title font-display heading-page reveal text-stone-900 mb-4">
        <span class="origen-hero-line" data-full-text="{{ section.settings.manos_title }}">{{ section.settings.manos_title }}</span>
      </h2>
      <p class="font-geist-mono text-[11px] md:text-xs uppercase tracking-[0.18em] text-[#6A6A6A] leading-relaxed">
        {{ section.settings.manos_text }}
      </p>
    </div>
  </div>
</section>

<!-- 4. MIRADA (idea) -->
<section class="min-h-[140vh] flex items-center justify-center px-6">
  <div class="reveal text-center max-w-[640px] mx-auto">
    <h2 class="espacio-title font-display heading-page reveal text-stone-900 mb-6">
      <span class="origen-hero-line" data-full-text="{{ section.settings.mirada_title }}">{{ section.settings.mirada_title }}</span>
    </h2>
    <p class="text-base md:text-lg reveal delay-100 text-[#6A6A6A]">
      <span class="block tracking-[0.32em] uppercase text-[11px] md:text-xs font-geist-mono">
        {{ section.settings.mirada_text | newline_to_br }}
      </span>
    </p>
  </div>
</section>

<!-- 5. EQUILIBRIO (síntesis) -->
<section class="min-h-[120vh] flex items-center justify-center px-6">
  <div class="reveal text-center">
    <h2 class="espacio-title font-display heading-page reveal text-stone-900">
      <span class="origen-hero-line" data-full-text="{{ section.settings.equilibrio_title }}">{{ section.settings.equilibrio_title }}</span>
    </h2>
  </div>
</section>

<!-- 6. LO ESENCIAL (objeto) -->
<section class="min-h-[140vh] flex items-center justify-center px-6">
  <div class="reveal flex flex-col items-center">
    {% if section.settings.bottle_image != blank %}
      <img src="{{ section.settings.bottle_image | image_url: width: 800 }}" alt="{{ section.settings.bottle_image_alt | escape }}" class="w-full max-w-[340px] md:max-w-[380px] h-auto object-contain mix-blend-multiply opacity-90 filter contrast-110 mb-10">
    {% endif %}
    <h2 class="espacio-title font-display heading-page reveal text-stone-900 mb-4 text-center">
      <span class="origen-hero-line" data-full-text="{{ section.settings.loesencial_title }}">{{ section.settings.loesencial_title }}</span>
    </h2>
    {% if section.settings.loesencial_link != blank %}
      <a href="{{ section.settings.loesencial_link }}" class="inline-block uppercase hover:text-[#111111] transition-colors duración-500 ease-out text-xs md:text-sm font-light tracking-tight font-geist-mono text-[#6A6A6A] border-b border-[#a0a09e] hover:border-[#111111] pb-1">
        {{ section.settings.loesencial_cta }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Albino Nosotros",
  "settings": [
    {
      "type": "header",
      "content": "1 · Origen"
    },
    {
      "type": "text",
      "id": "origen_title",
      "label": "Título origen",
