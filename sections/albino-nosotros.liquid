      "default": "Manos trabajando la vid"
    },
    {
      "type": "header",
      "content": "4 · Mirada"
    },
    {
      "type": "text",
      "id": "mirada_title",
      "label": "Título Mirada",
      "default": "Mirada"
    },
    {
      "type": "textarea",
      "id": "mirada_text",
