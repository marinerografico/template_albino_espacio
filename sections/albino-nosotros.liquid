    {
      "type": "header",
      "content": "5 · Equilibrio"
    },
    {
      "type": "text",
      "id": "equilibrio_title",
      "label": "Título Equilibrio",
      "default": "Equilibrio"
    },
    {
      "type": "header",
      "content": "6 · Lo esencial"
    },
    {
      "type": "image_picker",
      "id": "bottle_image",
      "label": "Imagen botella"
    },
    {
      "type": "text",
      "id": "bottle_image_alt",
      "label": "Alt imagen botella",
      "default": "Botella Albino"
    },
    {
      "type": "text",
      "id": "loesencial_title",
      "label": "Título Lo esencial",
      "default": "Lo esencial"
    },
    {
      "type": "url",
      "id": "loesencial_link",
      "label": "URL CTA Lo esencial"
    },
    {
      "type": "text",
      "id": "loesencial_cta",
      "label": "Texto CTA Lo esencial",
      "default": "Descubrir la edición"
    }
  ],
  "presets": [
    {
      "name": "Albino Nosotros",
      "settings": {}
    }
  ]
}
