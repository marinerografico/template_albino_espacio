{% comment %}
  Página Origen (antes Nosotros). Estructura simplificada:
  ORIGEN — TIERRA — ESFUERZO — Aquí empieza el vino — Imagen + CTA
{% endcomment %}
{% capture newline %}
{% endcapture %}

<!-- 1. ORIGEN -->
<section class="min-h-[120vh] flex items-center justify-center px-6 pt-32">
  <div class="text-center">
    <h1 class="espacio-title font-display heading-page reveal text-stone-900">
      {{ section.settings.origen_title }}
    </h1>
  </div>
</section>

<!-- Separador -->
<section class="py-12 px-6">
  <p class="text-center font-geist-mono text-stone-400 text-[10px] tracking-[0.2em]">—</p>
</section>

<!-- 2. TIERRA -->
<section class="min-h-[80vh] flex items-center justify-center px-6 md:px-12">
  <div class="w-full max-w-[560px] text-center">
    <h2 class="espacio-title font-display heading-page reveal text-stone-900 mb-2">
      {{ section.settings.tierra_title }}
    </h2>
    <p class="font-body text-[#6A6A6A] mb-8">
      {{ section.settings.tierra_subtitle }}
    </p>
    <div class="font-body text-stone-900 space-y-2 text-left">
      {% assign tierra_items = section.settings.tierra_lines | split: newline %}
      {% for line in tierra_items %}
        {% if line != blank %}<p class="mb-2 last:mb-0">{{ line | strip }}</p>{% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- Separador -->
<section class="py-12 px-6">
  <p class="text-center font-geist-mono text-stone-400 text-[10px] tracking-[0.2em]">—</p>
</section>

<!-- 3. ESFUERZO -->
<section class="min-h-[80vh] flex items-center justify-center px-6 md:px-12">
  <div class="w-full max-w-[560px] text-center">
    <h2 class="espacio-title font-display heading-page reveal text-stone-900 mb-6">
      {{ section.settings.esfuerzo_title }}
    </h2>
    <div class="font-body text-stone-900 space-y-2 text-left">
      {% assign esfuerzo_items = section.settings.esfuerzo_text | split: newline %}
      {% for line in esfuerzo_items %}
        {% if line != blank %}<p class="mb-2 last:mb-0">{{ line | strip }}</p>{% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- Separador -->
<section class="py-12 px-6">
  <p class="text-center font-geist-mono text-stone-400 text-[10px] tracking-[0.2em]">—</p>
</section>

<!-- 4. Aquí empieza el vino -->
<section class="min-h-[120vh] flex items-center justify-center px-6">
  <div class="reveal flex flex-col items-center text-center">
    <p class="font-display text-stone-900 mb-12 text-lg md:text-xl">
      {{ section.settings.cierre_text }}
    </p>
    {% if section.settings.cta_image != blank %}
      <img src="{{ section.settings.cta_image | image_url: width: 800 }}" alt="{{ section.settings.cta_image_alt | escape }}" class="w-full max-w-[340px] md:max-w-[380px] h-auto object-contain mix-blend-multiply opacity-90 filter contrast-110 mb-10">
    {% endif %}
    {% if section.settings.cta_url != blank and section.settings.cta_label != blank %}
      <a href="{{ section.settings.cta_url }}" class="inline-block uppercase hover:text-[#111111] transition-colors duration-500 ease-out text-xs md:text-sm font-light font-geist-mono text-[#6A6A6A] border-b border-[#a0a09e] hover:border-[#111111] pb-1">
        {{ section.settings.cta_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Origen",
  "settings": [
    {
      "type": "header",
      "content": "1 · Origen"
    },
    {
      "type": "text",
      "id": "origen_title",
      "label": "Título",
      "default": "ORIGEN"
    },
    {
      "type": "header",
      "content": "2 · Tierra"
    },
    {
      "type": "text",
      "id": "tierra_title",
      "label": "Título",
      "default": "TIERRA"
    },
    {
      "type": "text",
      "id": "tierra_subtitle",
      "label": "Subtítulo",
      "default": "Tierra de Barros, Extremadura"
    },
    {
      "type": "textarea",
      "id": "tierra_lines",
      "label": "Líneas (una por línea)",
      "default": "Arcilla roja.\nClima seco.\nUn paisaje abierto."
    },
    {
      "type": "header",
      "content": "3 · Esfuerzo"
    },
    {
      "type": "text",
      "id": "esfuerzo_title",
      "label": "Título",
      "default": "ESFUERZO"
    },
    {
      "type": "textarea",
      "id": "esfuerzo_text",
      "label": "Texto (multilínea)",
      "default": "Un trabajo que se repite cada año.\nSiempre afinándose."
    },
    {
      "type": "header",
      "content": "4 · Cierre e imagen"
    },
    {
      "type": "text",
      "id": "cierre_text",
      "label": "Texto de cierre",
      "default": "Aquí empieza el vino."
    },
    {
      "type": "image_picker",
      "id": "cta_image",
      "label": "Imagen (botella Albino)"
    },
    {
      "type": "text",
      "id": "cta_image_alt",
      "label": "Alt imagen",
      "default": "Botella Albino"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del CTA",
      "default": "Explorar la mirada"
    }
  ],
  "presets": [
    {
      "name": "Origen",
      "settings": {}
    }
  ]
}
{% endschema %}
