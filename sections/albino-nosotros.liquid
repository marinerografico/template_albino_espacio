    {
      "type": "image_picker",
      "id": "tierra_image",
      "label": "Imagen Tierra (fallback si no hay vídeo)"
    },
    {
      "type": "text",
      "id": "tierra_image_alt",
      "label": "Alt imagen Tierra",
      "default": "Textura de tierra"
    },
    {
      "type": "header",
      "content": "3 · Manos"
    },
    {
      "type": "text",
      "id": "manos_title",
      "label": "Título Manos",
      "default": "Manos"
    },
    {
      "type": "textarea",
      "id": "manos_text",
