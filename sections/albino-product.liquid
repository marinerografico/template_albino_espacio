{% comment %}
  Sección página de producto: formulario add-to-cart con variante y cantidad.
  Usa el objeto global product disponible en templates de producto.
{% endcomment %}

{% assign product = product | default: nil %}
{% if product == blank %}
  <section class="py-24 px-6 text-center">
    <p class="text-stone-600">Selecciona un producto en el administrador.</p>
  </section>
{% else %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_media = current_variant.featured_media | default: product.featured_media %}

<section class="py-16 md:py-24 lg:py-32 px-6 max-w-[1200px] mx-auto">
  <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
    <div class="reveal">
      {% if featured_media %}
        <img
          src="{{ featured_media | image_url: width: 800 }}"
          alt="{{ featured_media.alt | default: product.title | escape }}"
          class="w-full max-h-[70vh] object-contain"
          width="800"
          height="{{ 800 | divided_by: featured_media.aspect_ratio | round }}"
          loading="eager"
        >
      {% else %}
        <div class="aspect-[3/4] bg-[#e5e4e1] flex items-center justify-center text-stone-500 font-geist-mono text-sm uppercase tracking-widest">
          Sin imagen
        </div>
      {% endif %}
    </div>

    <div class="reveal">
      <h1 class="espacio-title font-display uppercase text-[18px] leading-[22px] text-stone-900" style="letter-spacing: normal;">
        {{ product.title }}
      </h1>
      <p class="mt-4 text-2xl font-light tracking-tight text-stone-900">
        <span class="font-geist-mono text-sm uppercase tracking-[0.32em] text-stone-600">{{ product.type }}</span>
      </p>

      <p class="mt-6 text-lg font-geist-mono font-light text-stone-900">
        {{ current_variant.price | money_without_trailing_zeros }}
        {% if current_variant.compare_at_price > current_variant.price %}
          <span class="ml-2 text-stone-500 line-through">{{ current_variant.compare_at_price | money_without_trailing_zeros }}</span>
        {% endif %}
      </p>

      {% if product.description != blank %}
        <div class="mt-6 text-stone-700 font-body font-light leading-relaxed">
          {{ product.description }}
        </div>
      {% endif %}

      <p id="product-form-error" class="hidden mt-3 text-sm text-red-600 font-body" role="alert"></p>
      {% form 'product', product, id: 'product-form-albino', class: 'mt-10', data_product_add_form: '' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-variant-id>

        {% if product.variants.size > 1 %}
          <div class="mb-6">
            <label class="block text-xs font-geist-mono uppercase tracking-[0.18em] text-stone-600 mb-2">Variante</label>
            <select
              class="w-full max-w-sm border border-[#e5e4e1] bg-[#F5F4F1] px-4 py-3 font-body text-stone-900 focus:outline-none focus:ring-2 focus:ring-[#B56B80]"
              data-product-variant-select
              aria-label="Elegir variante"
            >
              {% for variant in product.variants %}
                <option
                  value="{{ variant.id }}"
                  {% if variant.id == current_variant.id %}selected{% endif %}
                  {% unless variant.available %}disabled{% endunless %}
                >
                  {{ variant.title }}{% unless variant.available %} — Agotado{% endunless %}
                </option>
              {% endfor %}
            </select>
          </div>
        {% endif %}

        <div class="mb-6">
          <label class="block text-xs font-geist-mono uppercase tracking-[0.18em] text-stone-600 mb-2" for="quantity-product-albino">Cantidad</label>
          <input
            type="number"
            id="quantity-product-albino"
            name="quantity"
            value="1"
            min="1"
            max="99"
            class="w-24 border border-[#e5e4e1] bg-[#F5F4F1] px-4 py-3 font-body text-stone-900 focus:outline-none focus:ring-2 focus:ring-[#B56B80]"
          >
        </div>

        <button
          type="submit"
          name="add"
          class="inline-block uppercase hover:bg-[#111111] hover:text-[#F5F4F1] transition-colors duration-300 text-xs md:text-sm font-light tracking-tight font-geist-mono border border-[#111111] rounded-none pt-4 pr-10 pb-4 pl-10 text-stone-900 disabled:opacity-50 disabled:cursor-not-allowed"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {% if current_variant.available %}
            {{ section.settings.add_to_cart_label | default: 'Añadir al carrito' }}
          {% else %}
            {{ section.settings.sold_out_label | default: 'Agotado' }}
          {% endif %}
        </button>

        {% if section.settings.show_secondary_link %}
          <a
            href="{{ section.settings.secondary_link | default: routes.root_url }}"
            class="ml-4 md:ml-6 inline-block uppercase text-xs md:text-sm font-light tracking-tight font-geist-mono border-b border-[#a0a09e] hover:border-[#111111] pb-1 text-stone-900"
          >
            {{ section.settings.secondary_link_label | default: 'Seguir comprando' }}
          </a>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Producto Albino",
  "tag": "section",
  "class": "section-product-albino",
  "settings": [
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Texto del botón añadir al carrito",
      "default": "Añadir al carrito"
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "Texto cuando está agotado",
      "default": "Agotado"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_link",
      "label": "Mostrar enlace secundario",
      "default": true
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "URL del enlace secundario"
    },
    {
      "type": "text",
      "id": "secondary_link_label",
      "label": "Texto del enlace secundario",
      "default": "Seguir comprando"
    }
  ]
}
{% endschema %}
