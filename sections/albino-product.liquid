{% comment %}
  Sección página de producto: formulario add-to-cart con variante y cantidad.
  Usa el objeto global product disponible en templates de producto.
{% endcomment %}

{% assign product = product | default: nil %}
{% if product == blank %}
  <section class="py-24 px-6 text-center">
    <p class="text-stone-600">Selecciona un producto en el administrador.</p>
  </section>
{% else %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_media = current_variant.featured_media | default: product.featured_media %}

<section class="py-16 md:py-24 lg:py-32 px-6 max-w-[1200px] mx-auto">
  <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
    <div class="reveal">
      {% if featured_media %}
        <img
          src="{{ featured_media | image_url: width: 800 }}"
          alt="{{ featured_media.alt | default: product.title | escape }}"
          class="w-full max-h-[70vh] object-contain"
          width="800"
          height="{{ 800 | divided_by: featured_media.aspect_ratio | round }}"
          loading="eager"
        >
      {% else %}
        <div class="aspect-[3/4] bg-[#e5e4e1] flex items-center justify-center text-stone-500 font-geist-mono text-sm uppercase tracking-widest">
          Sin imagen
        </div>
      {% endif %}
    </div>

    <div class="reveal">
      <h1 class="espacio-title font-display uppercase text-[18px] leading-[22px] text-stone-900" style="letter-spacing: normal;">
        {{ product.title }}
      </h1>
      <p class="mt-4 text-2xl font-light tracking-tight text-stone-900">
        <span class="font-geist-mono text-sm uppercase tracking-[0.32em] text-stone-600">{{ product.type }}</span>
      </p>

      <p class="mt-6 text-lg font-geist-mono font-light text-stone-900">
        {{ current_variant.price | money_without_trailing_zeros }}
        {% if current_variant.compare_at_price > current_variant.price %}
          <span class="ml-2 text-stone-500 line-through">{{ current_variant.compare_at_price | money_without_trailing_zeros }}</span>
        {% endif %}
      </p>

      {% if product.description != blank %}
        <div class="mt-6 text-stone-700 font-body font-light leading-relaxed">
          {{ product.description }}
        </div>
      {% endif %}

      <p id="product-form-error" class="hidden mt-6 mb-4 text-sm text-red-600 font-body" role="alert"></p>

      <div class="mt-10 flex flex-col sm:flex-row sm:items-center gap-6 border-t border-[#e5e4e1] pt-6">
        <div class="flex flex-col items-start gap-1">
          <span class="text-xs font-geist-mono uppercase tracking-[0.2em] text-stone-500">Edición actual</span>
          <span class="text-lg md:text-xl font-geist-mono font-light tracking-tight text-stone-900">
            {{ current_variant.price | money_without_trailing_zeros }}
          </span>
        </div>
        <div class="flex items-center gap-4 sm:ml-auto">
          {% if current_variant.available %}
            <button
              type="button"
              class="inline-block uppercase hover:bg-[#111111] hover:text-[#F5F4F1] transition-colors duración-300 text-xs md:text-sm font-light tracking-tight font-geist-mono border border-[#111111] rounded-none pt-3 pr-8 pb-3 pl-8 text-stone-900"
              data-add-to-cart
              data-variant-id="{{ current_variant.id }}"
            >
              {{ section.settings.add_to_cart_label | default: 'Añadir al carrito' }}
            </button>
          {% else %}
            <span class="text-xs md:text-sm font-geist-mono uppercase tracking-[0.18em] text-stone-500">
              {{ section.settings.sold_out_label | default: 'Agotado' }}
            </span>
          {% endif %}

          {% if section.settings.show_secondary_link %}
            <a
              href="{{ section.settings.secondary_link | default: routes.root_url }}"
              class="inline-block uppercase text-xs md:text-sm font-light tracking-tight font-geist-mono border-b border-[#a0a09e] hover:border-[#111111] pb-1 text-stone-900"
            >
              {{ section.settings.secondary_link_label | default: 'Ver todos los packs' }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Bloque SEO contextual: texto semántico para Google y GEO (vino contemporáneo, Tierra de Barros, Extremadura) {%- endcomment -%}
  {% if section.settings.show_seo_block %}
    <div class="reveal mt-16 md:mt-24 pt-10 border-t border-[#e5e4e1]">
      <div class="max-w-[720px]">
        <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-600">
          {{ section.settings.seo_text | default: product.description | default: 'Albino es un vino tinto dulce elaborado con uva Tempranillo procedente de viñedos situados en Tierra de Barros, Extremadura. La primera edición explora una mirada contemporánea sobre el vino y el territorio, combinando tradición familiar con diseño actual. Producción limitada.' }}
        </p>
      </div>
    </div>
  {% endif %}
</section>
{% endif %}

{% schema %}
{
  "name": "Producto Albino",
  "tag": "section",
  "class": "section-product-albino",
  "settings": [
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Texto del botón añadir al carrito",
      "default": "Añadir al carrito"
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "Texto cuando está agotado",
      "default": "Agotado"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_link",
      "label": "Mostrar enlace secundario",
      "default": true
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "URL del enlace secundario"
    },
    {
      "type": "text",
      "id": "secondary_link_label",
      "label": "Texto del enlace secundario",
      "default": "Seguir comprando"
    },
    {
      "type": "header",
      "content": "SEO contextual"
    },
    {
      "type": "checkbox",
      "id": "show_seo_block",
      "label": "Mostrar bloque de texto contextual (SEO/GEO)",
      "default": true
    },
    {
      "type": "textarea",
      "id": "seo_text",
      "label": "Texto contextual del producto",
      "info": "Para Google y motores de IA. Incluye: Tierra de Barros, Extremadura, Tempranillo, vino contemporáneo.",
      "default": "Albino es un vino tinto dulce elaborado con uva Tempranillo procedente de viñedos situados en Tierra de Barros, Extremadura. La primera edición explora una mirada contemporánea sobre el vino y el territorio, combinando tradición familiar con diseño actual. Producción limitada."
    }
  ]
}
{% endschema %}
