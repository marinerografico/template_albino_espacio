{% comment %}
  Journal — artículo individual. Una página = un artículo completo.
  Usar plantilla "journal-article" en una página y rellenar esta sección.
{% endcomment %}

<section class="px-6 pt-32 pb-24 md:pt-40 md:pb-40 lg:pt-48 lg:pb-48 bg-[#F5F4F1]" aria-labelledby="article-title">
  <div class="max-w-[1040px] mx-auto">
    <header class="reveal-editorial mb-10 md:mb-12">
      <a href="{{ routes.root_url }}pages/journal" class="inline-block font-geist-mono text-[11px] md:text-xs uppercase tracking-[0.25em] text-stone-500 hover:text-stone-900 mb-6 transition-colors">
        ← Journal
      </a>
      {% if section.settings.kicker != blank %}
        <p class="font-geist-mono text-[11px] md:text-xs uppercase tracking-[0.25em] text-stone-500 mb-4">
          {{ section.settings.kicker }}
        </p>
      {% endif %}
      <h1 id="article-title" class="espacio-title font-display heading-page text-stone-900 mb-6">
        {{ section.settings.title | default: page.title }}
      </h1>
      {% if section.settings.intro != blank %}
        <p class="max-w-[720px] text-sm md:text-base font-body font-light text-stone-700 leading-relaxed">
          {{ section.settings.intro }}
        </p>
      {% endif %}
    </header>

    <article class="reveal-editorial border-t border-[#e5e4e1] pt-10 md:pt-12">
      <div class="grid md:grid-cols-[minmax(0,3fr)_minmax(0,2fr)] gap-10 md:gap-16 items-start">
        <div>
          {% if section.settings.body_1 != blank %}
            <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800 mb-4">
              {{ section.settings.body_1 }}
            </p>
          {% endif %}
          {% if section.settings.body_2 != blank %}
            <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800 mb-4">
              {{ section.settings.body_2 }}
            </p>
          {% endif %}
          {% if section.settings.body_3 != blank %}
            <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800 mb-4">
              {{ section.settings.body_3 }}
            </p>
          {% endif %}

          {% if section.settings.show_geo_context %}
            <section class="mt-8 pt-6 border-t border-[#e5e4e1]">
              <h2 class="text-sm md:text-base font-geist-mono uppercase tracking-[0.18em] text-stone-500 mb-3">
                {{ section.settings.geo_title }}
              </h2>
              {% if section.settings.geo_p1 != blank %}
                <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800 mb-3">
                  {{ section.settings.geo_p1 }}
                </p>
              {% endif %}
              {% if section.settings.geo_p2 != blank %}
                <p class="text-sm md:text-base font-body font-light leading-relaxed text-stone-800">
                  {{ section.settings.geo_p2 }}
                </p>
              {% endif %}
            </section>
          {% endif %}
        </div>
        <figure class="md:justify-self-end">
          {% if section.settings.image != blank %}
            <img
              src="{{ section.settings.image | image_url: width: 800 }}"
              alt="{{ section.settings.image_alt | default: section.settings.title | escape }}"
              loading="lazy"
              class="w-full h-auto object-cover aspect-[4/3]"
              width="800"
              height="600"
            >
          {% else %}
            <img
              src="{{ 'journal-placeholder.jpg' | asset_url }}"
              alt="{{ section.settings.title | escape }}"
              loading="lazy"
              class="w-full h-auto object-cover aspect-[4/3]"
              width="800"
              height="600"
            >
          {% endif %}
          {% if section.settings.caption != blank %}
            <figcaption class="mt-3 text-[11px] md:text-xs font-geist-mono uppercase tracking-[0.18em] text-stone-500">
              {{ section.settings.caption }}
            </figcaption>
          {% endif %}
        </figure>
      </div>
    </article>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": ["Article", "BlogPosting"],
  "headline": {{ section.settings.title | default: page.title | json }},
  "description": {{ section.settings.intro | default: section.settings.body_1 | truncate: 200 | json }},
  "author": { "@type": "Organization", "name": "Albino" },
  "publisher": { "@id": "{{ shop.url }}/#organization" },
  "mainEntityOfPage": "{{ canonical_url }}",
  "url": "{{ canonical_url }}",
  "inLanguage": "{{ request.locale.iso_code | default: 'es' }}"
}
</script>

{% schema %}
{
  "name": "Journal — Artículo",
  "settings": [
    { "type": "header", "content": "Cabecera del artículo" },
    { "type": "text", "id": "title", "label": "Título", "default": "Tierra de Barros" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Suelo · Origen · Extremadura" },
    { "type": "textarea", "id": "intro", "label": "Introducción", "default": "Tierra de Barros es una comarca del sur de Extremadura donde la arcilla aparece a simple vista." },
    { "type": "header", "content": "Cuerpo" },
    { "type": "textarea", "id": "body_1", "label": "Párrafo 1" },
    { "type": "textarea", "id": "body_2", "label": "Párrafo 2" },
    { "type": "textarea", "id": "body_3", "label": "Párrafo 3" },
    { "type": "header", "content": "Imagen" },
    { "type": "image_picker", "id": "image", "label": "Imagen" },
    { "type": "text", "id": "image_alt", "label": "Alt de la imagen" },
    { "type": "text", "id": "caption", "label": "Pie de foto" },
    { "type": "header", "content": "Bloque Sobre Albino (GEO)" },
    { "type": "checkbox", "id": "show_geo_context", "label": "Mostrar bloque 'Sobre Albino'", "default": true },
    { "type": "text", "id": "geo_title", "label": "Título", "default": "Sobre Albino" },
    { "type": "textarea", "id": "geo_p1", "label": "Párrafo 1" },
    { "type": "textarea", "id": "geo_p2", "label": "Párrafo 2" }
  ]
}
{% endschema %}
