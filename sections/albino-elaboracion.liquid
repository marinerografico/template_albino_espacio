{% comment %} Sección Nosotros: proceso en 5 etapas, totalmente editable. {% endcomment %}
<h1 class="sr-only">{{ shop.name }} — Nosotros</h1>

<section class="min-h-[90vh] flex flex-col items-center justify-center pt-32 px-6">
  <div class="text-center">
    <h2 class="espacio-title font-display heading-page reveal text-stone-900">
      {{ section.settings.hero_title }}
    </h2>
  </div>
</section>

<div class="max-w-[1400px] mx-auto px-6 lg:px-12 flex flex-col pb-32">
  <div class="w-[1px] h-32 md:h-48 bg-[#e5e4e1] mx-auto mb-24 md:mb-32 reveal"></div>

  <!-- Etapa 1 -->
  <section class="min-h-[80vh] flex flex-col md:flex-row items-center gap-16 md:gap-24 lg:gap-32 py-16 md:py-24">
    <div class="w-full md:w-1/2 reveal order-1 flex justify-center md:justify-end">
      <img src="{{ section.settings.stage1_image | default: 'https://via.placeholder.com/500x625' }}"
           class="w-full max-w-[500px] aspect-[4/5] object-cover filter grayscale-[15%] contrast-110"
           alt="{{ section.settings.stage1_image_alt }}" width="500" height="625">
    </div>
    <div class="w-full md:w-1/2 reveal delay-200 order-2 flex flex-col justify-center">
      <span class="font-geist-mono text-[10px] md:text-xs uppercase tracking-[0.2em] text-[#B56B80] mb-6 block">
        {{ section.settings.stage1_label }}
      </span>
      <h3 class="font-display text-4xl md:text-5xl lg:text-6xl font-light tracking-tight text-[#111111] mb-8">
        {{ section.settings.stage1_title }}
      </h3>
      <p class="font-body text-base md:text-lg text-[#6A6A6A] leading-[1.6] font-light max-w-[400px]">
        {{ section.settings.stage1_text }}
      </p>
    </div>
  </section>

  <div class="w-[1px] h-32 md:h-48 bg-[#e5e4e1] mx-auto my-16 md:my-24 reveal"></div>

  <!-- Etapa 2 -->
  <section class="min-h-[80vh] flex flex-col md:flex-row items-center gap-16 md:gap-24 lg:gap-32 py-16 md:py-24">
    <div class="w-full md:w-1/2 reveal delay-200 order-2 md:order-1 flex flex-col justify-center md:items-end text-left md:text-right">
      <div class="max-w-[400px]">
        <span class="font-geist-mono text-[10px] md:text-xs uppercase tracking-[0.2em] text-[#B56B80] mb-6 block">
          {{ section.settings.stage2_label }}
        </span>
        <h3 class="font-display text-4xl md:text-5xl lg:text-6xl font-light tracking-tight text-[#111111] mb-8">
          {{ section.settings.stage2_title }}
        </h3>
        <p class="font-body text-base md:text-lg text-[#6A6A6A] leading-[1.6] font-light">
          {{ section.settings.stage2_text }}
        </p>
      </div>
    </div>
    <div class="w-full md:w-1/2 reveal order-1 md:order-2 flex justify-center md:justify-start">
      <img src="{{ section.settings.stage2_image | default: 'https://via.placeholder.com/500x625' }}"
           class="w-full max-w-[500px] aspect-[4/5] object-cover filter grayscale-[30%] contrast-110"
           alt="{{ section.settings.stage2_image_alt }}" width="500" height="625">
    </div>
  </section>

  <div class="w-[1px] h-32 md:h-48 bg-[#e5e4e1] mx-auto my-16 md:my-24 reveal"></div>

  <!-- Etapa 3 -->
  <section class="min-h-[80vh] flex flex-col md:flex-row items-center gap-16 md:gap-24 lg:gap-32 py-16 md:py-24">
