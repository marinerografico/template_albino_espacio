    },
    {
      "type": "textarea",
      "id": "stage3_text",
      "label": "Texto etapa 3",
      "default": " "
    },
    {
      "type": "url",
      "id": "stage3_image",
      "label": "Imagen etapa 3 (URL)"
    },
    {
      "type": "text",
      "id": "stage3_image_alt",
      "label": "Alt imagen etapa 3",
      "default": "Uvas en mano durante la vendimia"
    },
    {
      "type": "header",
      "content": "Etapa 4"
    },
    {
      "type": "text",
      "id": "stage4_label",
      "label": "Etiqueta etapa 4",
      "default": "04 · ALBINO"
    },
    {
      "type": "text",
      "id": "stage4_title",
      "label": "Título etapa 4",
      "default": "Esencial."
    },
    {
      "type": "textarea",
      "id": "stage4_text",
      "label": "Texto etapa 4",
      "default": "La raíz es la misma. La mirada es nueva."
    },
    {
      "type": "url",
