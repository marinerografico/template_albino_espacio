    {
      "type": "textarea",
      "id": "stage5_text",
      "label": "Texto etapa 5",
      "default": "Producción limitada. Cosecha 2025. Tierra de Barros."
    },
    {
      "type": "url",
      "id": "stage5_image",
      "label": "Imagen etapa 5 (URL)"
    },
    {
      "type": "text",
      "id": "stage5_image_alt",
      "label": "Alt imagen etapa 5",
      "default": "Botella Albino"
    },
    {
      "type": "text",
      "id": "stage5_cta_label",
      "label": "Texto CTA final",
      "default": "Descubrir la edición"
    },
    {
      "type": "url",
      "id": "stage5_cta_link",
      "label": "URL CTA final"
