{% comment %}
  MIRADA — Experiencia NFC editorial para Albino.
  Mobile-first, premium, minimal. Dos modos: inmersivo y accesible.
  mirada.css se carga en el head (layout) para evitar FOUC en el hero.
{% endcomment %}

<div class="mirada-page" id="mirada-page-root"
  data-audio-intro="{% if section.settings.audio_intro != blank %}{{ section.settings.audio_intro }}{% endif %}"
  data-audio-product="{% if section.settings.audio_product_info != blank %}{{ section.settings.audio_product_info }}{% endif %}"
  data-audio-nutrition="{% if section.settings.audio_nutrition != blank %}{{ section.settings.audio_nutrition }}{% endif %}"
  data-audio-discover="{% if section.settings.audio_discover != blank %}{{ section.settings.audio_discover }}{% endif %}"
  data-audio-learn-intro="{% if section.settings.audio_learn_intro != blank %}{{ section.settings.audio_learn_intro }}{% endif %}"
  data-audio-step-1="{% if section.settings.audio_step_1 != blank %}{{ section.settings.audio_step_1 }}{% endif %}"
  data-audio-step-2="{% if section.settings.audio_step_2 != blank %}{{ section.settings.audio_step_2 }}{% endif %}"
  data-audio-step-3="{% if section.settings.audio_step_3 != blank %}{{ section.settings.audio_step_3 }}{% endif %}"
  data-audio-step-4="{% if section.settings.audio_step_4 != blank %}{{ section.settings.audio_step_4 }}{% endif %}"
  data-audio-outro="{% if section.settings.audio_outro != blank %}{{ section.settings.audio_outro }}{% endif %}"
  data-product-url="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}">
  <button type="button" id="btn-accessible-toggle" class="mirada-accessible-tag" aria-pressed="false" aria-label="Usar modo accesible">Modo accesible</button>
  <h1 class="sr-only">{{ shop.name }} — El vino que cambia la mirada</h1>

  <div id="mirada-audio-band" class="mirada-audio-band" aria-live="polite" hidden>
    Audio activado
  </div>

  <main>
    <!-- 1. HERO / ENTRY -->
    <section id="mirada-hero" class="mirada-section mirada-hero" aria-labelledby="hero-title">
      <div class="mirada-hero-inner">
        <p class="mirada-label reveal">Albino</p>
        <h2 id="hero-title" class="mirada-heading reveal">El vino que cambia la mirada</h2>
        <p class="mirada-hero-sub reveal delay-100">Has escaneado la etiqueta sonora de Albino.</p>

        <div class="mirada-hero-actions" role="group" aria-label="Elegir modo de experiencia">
          <button type="button" id="btn-audio-on" class="mirada-btn mirada-btn-primary" aria-pressed="false">
            Activar experiencia sonora
          </button>
          <button type="button" id="btn-audio-off" class="mirada-btn mirada-btn-secondary" aria-pressed="true">
            Explorar sin audio
          </button>
        </div>

        <p id="audio-status" class="mirada-audio-status" aria-live="polite" hidden>
          Experiencia sonora activada.
        </p>
        <p id="accessible-mode-msg" class="mirada-accessible-msg" aria-live="polite" hidden>
          Esta experiencia se adapta a tu forma de escuchar.
        </p>

        <nav class="mirada-quick-links reveal delay-200" aria-label="Accesos rápidos">
          <a href="#product-info" class="mirada-link">Información del vino</a>
          <a href="#learn-to-look" class="mirada-link">Aprender a mirarlo</a>
        </nav>
      </div>
    </section>

    <!-- 2. PRODUCT INFORMATION -->
    <section id="product-info" class="mirada-section mirada-product" aria-labelledby="product-title">
      <div class="mirada-block">
        <h2 id="product-title" class="mirada-heading reveal">Información del vino</h2>
        <dl class="mirada-dl reveal delay-100">
          <div class="mirada-dl-row"><dt>Nombre</dt><dd>Albino</dd></div>
          <div class="mirada-dl-row"><dt>Tipo</dt><dd>Vino tinto dulce joven</dd></div>
          <div class="mirada-dl-row"><dt>Variedad</dt><dd>Tempranillo</dd></div>
          <div class="mirada-dl-row"><dt>Origen</dt><dd>Tierra de Barros · Extremadura</dd></div>
          <div class="mirada-dl-row"><dt>Alcohol</dt><dd>12,5 % vol</dd></div>
          <div class="mirada-dl-row"><dt>Formato</dt><dd>75 cl</dd></div>
          <div class="mirada-dl-row mirada-dl-row-last"><dt>Alérgenos</dt><dd>Contiene sulfitos</dd></div>
        </dl>
        <div class="mirada-product-actions reveal delay-200">
          <button type="button" id="btn-toggle-nutrition" class="mirada-btn mirada-btn-primary" aria-expanded="false" aria-controls="nutrition-info">
            Ver información nutricional
          </button>
          <a href="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}" class="mirada-btn mirada-btn-secondary">
            Ver botella
          </a>
          <button type="button" id="btn-audio-product" class="mirada-btn mirada-btn-audio" aria-label="Escuchar información del vino" hidden>
            Escuchar
          </button>
        </div>
      </div>
    </section>

    <!-- 3. NUTRITION INFORMATION -->
    <section id="nutrition-info" class="mirada-section mirada-nutrition" aria-labelledby="nutrition-title" hidden>
      <div class="mirada-block">
        <h2 id="nutrition-title" class="mirada-heading reveal">Información nutricional</h2>
        <p class="mirada-label reveal delay-100">Valores por 100 ml</p>
        <table class="mirada-table reveal delay-100" role="table" aria-describedby="nutrition-title">
          <caption class="sr-only">Valores nutricionales por 100 ml de vino Albino</caption>
          <tbody>
            <tr><td>Energía</td><td>350 kJ / 85 kcal</td></tr>
            <tr><td>Carbohidratos</td><td>4 g</td></tr>
            <tr><td>de los cuales azúcares</td><td>4 g</td></tr>
            <tr><td>Grasas</td><td>0 g</td></tr>
            <tr><td>Proteínas</td><td>0 g</td></tr>
            <tr><td>Sal</td><td>0 g</td></tr>
          </tbody>
        </table>
        <p class="mirada-nutrition-note reveal delay-200">Consumir con responsabilidad.</p>
      </div>
    </section>

    <!-- 4. DESCUBRIR EL VINO -->
    <section id="discover-wine" class="mirada-section mirada-discover" aria-labelledby="discover-title">
      <div class="mirada-block mirada-discover-block">
        <h2 id="discover-title" class="mirada-heading reveal">Descubrir el vino</h2>
        <div class="mirada-discover-content reveal delay-100">
          <p>Albino nace en Tierra de Barros, en Extremadura.</p>
          <p>Un vino tinto dulce de la variedad tempranillo.</p>
          <p>Un vino cercano. Pensado para compartir.</p>
          <p>Albino no pretende reinventar el vino. Solo propone mirarlo de otra manera.</p>
        </div>
      </div>
    </section>

    <!-- 5. APRENDER A MIRARLO -->
    <section id="learn-to-look" class="mirada-learn" aria-labelledby="learn-title">
      <div class="mirada-learn-intro reveal" id="learn-intro">
        <h2 id="learn-title" class="mirada-heading">Aprender a mirarlo</h2>
        <p class="mirada-learn-intro-text">Esta no es una cata tradicional.
Es una invitación a percibir el momento.</p>
        <button type="button" id="btn-audio-learn" class="mirada-btn mirada-btn-audio" aria-label="Escuchar recorrido guiado de los 4 momentos" hidden>
          Escuchar recorrido
        </button>
      </div>

      <article id="step-1" class="learn-moment" aria-labelledby="step-1-title" data-step="1">
        <div class="learn-moment-bg" aria-hidden="true">
          {% if section.settings.video_step_1 != blank %}
            <video class="learn-moment-video" autoplay muted loop playsinline aria-hidden="true">
              <source src="{{ section.settings.video_step_1 | escape }}" type="video/mp4">
            </video>
          {% else %}
            <div class="learn-moment-bg-fallback"></div>
          {% endif %}
          <div class="learn-moment-overlay"></div>
        </div>
        <div class="learn-moment-content">
          <p class="learn-moment-num" aria-hidden="true">01</p>
          <h3 id="step-1-title" class="learn-moment-title">Mira el momento</h3>
          <p class="learn-moment-text">Antes de probar el vino, tómate un momento. Cada persona mira el mundo de una forma distinta. A veces con los ojos. A veces con los sentidos.</p>
        </div>
      </article>

      <article id="step-2" class="learn-moment" aria-labelledby="step-2-title" data-step="2">
        <div class="learn-moment-bg" aria-hidden="true">
          {% if section.settings.video_step_2 != blank %}
            <video class="learn-moment-video" autoplay muted loop playsinline aria-hidden="true">
              <source src="{{ section.settings.video_step_2 | escape }}" type="video/mp4">
            </video>
          {% else %}
            <div class="learn-moment-bg-fallback"></div>
          {% endif %}
          <div class="learn-moment-overlay"></div>
        </div>
        <div class="learn-moment-content">
          <p class="learn-moment-num" aria-hidden="true">02</p>
          <h3 id="step-2-title" class="learn-moment-title">Acércate al vino</h3>
          <p class="learn-moment-text">Acerca la copa. No hace falta encontrar palabras. Solo percibe.</p>
        </div>
      </article>

      <article id="step-3" class="learn-moment" aria-labelledby="step-3-title" data-step="3">
        <div class="learn-moment-bg" aria-hidden="true">
          {% if section.settings.video_step_3 != blank %}
            <video class="learn-moment-video" autoplay muted loop playsinline aria-hidden="true">
              <source src="{{ section.settings.video_step_3 | escape }}" type="video/mp4">
            </video>
          {% else %}
            <div class="learn-moment-bg-fallback"></div>
          {% endif %}
          <div class="learn-moment-overlay"></div>
        </div>
        <div class="learn-moment-content">
          <p class="learn-moment-num" aria-hidden="true">03</p>
          <h3 id="step-3-title" class="learn-moment-title">Prueba</h3>
          <p class="learn-moment-text">Bebe despacio. No intentes entenderlo todo. Solo deja que ocurra.</p>
        </div>
      </article>

      <article id="step-4" class="learn-moment" aria-labelledby="step-4-title" data-step="4">
        <div class="learn-moment-bg" aria-hidden="true">
          {% if section.settings.video_step_4 != blank %}
            <video class="learn-moment-video" autoplay muted loop playsinline aria-hidden="true">
              <source src="{{ section.settings.video_step_4 | escape }}" type="video/mp4">
            </video>
          {% else %}
            <div class="learn-moment-bg-fallback"></div>
          {% endif %}
          <div class="learn-moment-overlay"></div>
        </div>
        <div class="learn-moment-content">
          <p class="learn-moment-num" aria-hidden="true">04</p>
          <h3 id="step-4-title" class="learn-moment-title">Vuelve a mirar</h3>
          <p class="learn-moment-text">Ahora vuelve a mirar el momento. Quizá no haya cambiado nada. O quizá sí. El vino no cambia el mundo. Solo cambia la forma de mirarlo.</p>
        </div>
      </article>
    </section>

    <!-- 6. ARCHIVO DE MIRADAS -->
    <section id="miradas-form" class="mirada-section mirada-archive" aria-labelledby="miradas-title">
      <div class="mirada-block">
        <h2 id="miradas-title" class="mirada-heading reveal">¿Cómo ves este vino?</h2>
        <p class="mirada-archive-intro reveal delay-100">Cada persona ve Albino de una manera distinta.
Esta también puede ser tu mirada.</p>
        <form id="form-miradas" class="mirada-form reveal delay-100" novalidate>
          <fieldset class="mirada-fieldset">
            <legend class="sr-only">Elige una opción</legend>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="cercano" class="mirada-radio"> Cercano</label>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="profundo" class="mirada-radio"> Profundo</label>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="inesperado" class="mirada-radio"> Inesperado</label>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="calido" class="mirada-radio"> Cálido</label>
          </fieldset>
          <label class="mirada-textarea-label" for="tu-mirada">
            <span class="mirada-textarea-label-text">Tu mirada</span>
            <textarea id="tu-mirada" name="tu_mirada" rows="3" placeholder="Opcional" class="mirada-textarea" aria-describedby="form-miradas-feedback"></textarea>
          </label>
          <div id="form-miradas-feedback" class="mirada-form-feedback" role="status" aria-live="polite" aria-atomic="true"></div>
          <button type="submit" class="mirada-btn mirada-btn-primary w-full">Dejar mi mirada</button>
        </form>
      </div>
    </section>

    <!-- 7. PRODUCT CTA -->
    <section id="mirada-cta" class="mirada-section mirada-cta" aria-labelledby="cta-title">
      <div class="mirada-block mirada-cta-block">
        <h2 id="cta-title" class="sr-only">Producto</h2>
        <div class="mirada-cta-actions">
          <a href="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}" class="mirada-btn mirada-btn-primary">Comprar botella</a>
          <a href="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}" class="mirada-link mirada-cta-link">Ver el vino</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="mirada-footer">
    <a href="{{ routes.root_url }}">
      {% if settings.logo != blank %}
        <img src="{{ settings.logo | image_url: width: 300 }}" alt="Logotipo de Albino, vino de Tierra de Barros" class="mirada-footer-logo" width="150" height="60" loading="lazy">
      {% else %}
        <img data-bind-src="assets.logo" alt="Logotipo de Albino, vino de Tierra de Barros" class="mirada-footer-logo" width="150" height="60" loading="lazy">
      {% endif %}
    </a>
  </footer>
</div>

<audio id="mirada-audio-player" preload="metadata" aria-hidden="true"></audio>

<script src="{{ 'mirada.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Mirada",
  "tag": "section",
  "class": "section-mirada",
  "settings": [
    {
      "type": "url",
      "id": "product_url",
      "label": "URL del producto"
    },
    {
      "type": "header",
      "content": "Vídeos de fondo (opcional)"
    },
    {
      "type": "text",
      "id": "video_step_1",
      "label": "Vídeo paso 1 — Mira el momento",
      "info": "URL del MP4 (Content → Files)"
    },
    {
      "type": "text",
      "id": "video_step_2",
      "label": "Vídeo paso 2 — Acércate al vino"
    },
    {
      "type": "text",
      "id": "video_step_3",
      "label": "Vídeo paso 3 — Prueba"
    },
    {
      "type": "text",
      "id": "video_step_4",
      "label": "Vídeo paso 4 — Vuelve a mirar"
    },
    {
      "type": "header",
      "content": "Audios — flujo completo"
    },
    {
      "type": "url",
      "id": "audio_intro",
      "label": "Audio intro — Hero (al activar experiencia sonora)"
    },
    {
      "type": "url",
      "id": "audio_product_info",
      "label": "Audio — Información del vino"
    },
    {
      "type": "url",
      "id": "audio_nutrition",
      "label": "Audio — Información nutricional"
    },
    {
      "type": "url",
      "id": "audio_discover",
      "label": "Audio — Descubrir el vino"
    },
    {
      "type": "url",
      "id": "audio_learn_intro",
      "label": "Audio — Intro Aprender a mirarlo"
    },
    {
      "type": "url",
      "id": "audio_step_1",
      "label": "Audio paso 1 — Mira el momento"
    },
    {
      "type": "url",
      "id": "audio_step_2",
      "label": "Audio paso 2 — Acércate al vino"
    },
    {
      "type": "url",
      "id": "audio_step_3",
      "label": "Audio paso 3 — Prueba"
    },
    {
      "type": "url",
      "id": "audio_step_4",
      "label": "Audio paso 4 — Vuelve a mirar"
    },
    {
      "type": "url",
      "id": "audio_outro",
      "label": "Audio — Cierre Archivo de miradas"
    }
  ]
}
{% endschema %}
