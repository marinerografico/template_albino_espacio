{% comment %}
  MIRADA — Etiqueta digital expandida. Legal first, experiencia editorial.
  Minimalista, limpio, ritmo pausado. Alterna bloques texto limpio y vídeo/imagen.
{% endcomment %}

<div class="mirada-page mirada-page-root" id="mirada-page-root"
  data-product-url="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}">
  <h1 class="sr-only">{{ shop.name }} — Información del vino Albino</h1>

  <main>
    <!-- BLOQUE 1 — ENTRADA / LEGAL FIRST -->
    <section id="mirada-hero" class="mirada-section mirada-hero" aria-labelledby="hero-title">
      <div class="mirada-block">
        <p class="mirada-label reveal">{{ section.settings.hero_title | default: 'ALBINO' }}</p>
        <p class="mirada-hero-sub reveal">{{ section.settings.hero_subtitle | default: 'Edición' }}</p>
        <a href="#product-info" class="mirada-btn mirada-btn-primary reveal delay-100">
          {{ section.settings.hero_cta | default: 'VER INFORMACIÓN DEL VINO' }}
        </a>
        <p class="mirada-hero-support reveal delay-200">{{ section.settings.hero_support | default: 'Información legal y nutricional' }}</p>
      </div>
    </section>

    <!-- BLOQUE 2 — INFORMACIÓN DEL VINO -->
    <section id="product-info" class="mirada-section mirada-product" aria-labelledby="product-title">
      <div class="mirada-block">
        <h2 id="product-title" class="mirada-heading reveal">{{ section.settings.product_title | default: 'INFORMACIÓN DEL VINO' }}</h2>
        <dl class="mirada-dl reveal delay-100">
          <div class="mirada-dl-row"><dt>Lugar</dt><dd>{{ section.settings.info_lugar | default: 'Tierra de Barros · Extremadura' }}</dd></div>
          <div class="mirada-dl-row"><dt>Tipo</dt><dd>{{ section.settings.info_tipo | default: 'Vino tinto dulce joven' }}</dd></div>
          <div class="mirada-dl-row"><dt>Variedad</dt><dd>{{ section.settings.info_variedad | default: 'Tempranillo' }}</dd></div>
          <div class="mirada-dl-row"><dt>Alcohol</dt><dd>{{ section.settings.info_alcohol | default: '12,5 % vol' }}</dd></div>
          <div class="mirada-dl-row"><dt>Formato</dt><dd>{{ section.settings.info_formato | default: '75 cl' }}</dd></div>
          <div class="mirada-dl-row mirada-dl-row-last"><dt>Alérgenos</dt><dd>{{ section.settings.info_alergenos | default: 'Contiene sulfitos' }}</dd></div>
        </dl>
        <div class="mirada-product-actions reveal delay-200">
          <a href="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}" class="mirada-btn mirada-btn-secondary">
            {{ section.settings.product_cta | default: 'VER ETIQUETA COMPLETA' }}
          </a>
        </div>
        <div class="mirada-nutrition-inline reveal delay-200">
          <p class="mirada-label">Información nutricional — Valores por 100 ml</p>
          <table class="mirada-table" role="table">
            <caption class="sr-only">Valores nutricionales por 100 ml</caption>
            <tbody>
              <tr><td>Energía</td><td>350 kJ / 85 kcal</td></tr>
              <tr><td>Carbohidratos</td><td>4 g</td></tr>
              <tr><td>de los cuales azúcares</td><td>4 g</td></tr>
              <tr><td>Grasas</td><td>0 g</td></tr>
              <tr><td>Proteínas</td><td>0 g</td></tr>
              <tr><td>Sal</td><td>0 g</td></tr>
            </tbody>
          </table>
          <p class="mirada-nutrition-note">Consumir con responsabilidad.</p>
        </div>
      </div>
    </section>

    <!-- BLOQUE 3 — TRANSICIÓN -->
    <section id="mirada-transition" class="mirada-section mirada-transition" aria-labelledby="transition-title">
      <div class="mirada-block">
        <p class="mirada-transition-text reveal">{{ section.settings.transition_text | default: 'La etiqueta contiene información.' }}</p>
        <p class="mirada-transition-text reveal delay-100">{{ section.settings.transition_text_2 | default: 'Pero no todo se entiende igual.' }}</p>
        <a href="#learn-step-1" class="mirada-btn mirada-btn-primary reveal delay-200">
          {{ section.settings.transition_cta | default: 'EXPLORAR LA MIRADA' }}
        </a>
      </div>
    </section>

    <!-- BLOQUE 4 — SECUENCIA (alterna texto limpio / vídeo) -->
    <section id="learn-to-look" class="mirada-learn" aria-labelledby="learn-title">

      <!-- 01 — TEXTO SOLO -->
      <article id="learn-step-1" class="learn-moment learn-moment-clean" aria-labelledby="step-1-title">
        <div class="learn-moment-content">
          <h3 id="step-1-title" class="learn-moment-title">{{ section.settings.step1_title | default: 'MIRA' }}</h3>
          <p class="learn-moment-text">{{ section.settings.step1_text | default: 'Observa la etiqueta.' }}</p>
          <p class="learn-moment-text">{{ section.settings.step1_text_2 | default: 'No busques entenderla.' }}</p>
        </div>
      </article>

      <!-- 02 — VÍDEO/IMAGEN -->
      <article id="learn-step-2" class="learn-moment learn-moment-media" aria-labelledby="step-2-title">
        <div class="learn-moment-bg" aria-hidden="true">
          {% if section.settings.video_step_2 != blank %}
            <video class="learn-moment-video" autoplay muted loop playsinline>
              <source src="{{ section.settings.video_step_2 | escape }}" type="video/mp4">
            </video>
          {% elsif section.settings.image_step_2 != blank %}
            <img src="{{ section.settings.image_step_2 | image_url: width: 1920 }}" class="learn-moment-img" alt="" loading="lazy">
          {% else %}
            <div class="learn-moment-bg-fallback"></div>
          {% endif %}
          <div class="learn-moment-overlay"></div>
        </div>
        <div class="learn-moment-content">
          <h3 id="step-2-title" class="learn-moment-title">{{ section.settings.step2_title | default: 'ACÉRCATE' }}</h3>
          <p class="learn-moment-text">{{ section.settings.step2_text | default: 'Sirve el vino.' }}</p>
          <p class="learn-moment-text">{{ section.settings.step2_text_2 | default: 'Mira cómo cambia con la luz.' }}</p>
        </div>
      </article>

      <!-- 03 — TEXTO SOLO -->
      <article id="learn-step-3" class="learn-moment learn-moment-clean" aria-labelledby="step-3-title">
        <div class="learn-moment-content">
          <h3 id="step-3-title" class="learn-moment-title">{{ section.settings.step3_title | default: 'PRUEBA' }}</h3>
          <p class="learn-moment-text">{{ section.settings.step3_text | default: 'Ahora sí.' }}</p>
          <p class="learn-moment-text">{{ section.settings.step3_text_2 | default: 'Y vuelve a mirar.' }}</p>
        </div>
      </article>

      <!-- 04 — VÍDEO/IMAGEN -->
      <article id="learn-step-4" class="learn-moment learn-moment-media" aria-labelledby="step-4-title">
        <div class="learn-moment-bg" aria-hidden="true">
          {% if section.settings.video_step_4 != blank %}
            <video class="learn-moment-video" autoplay muted loop playsinline>
              <source src="{{ section.settings.video_step_4 | escape }}" type="video/mp4">
            </video>
          {% elsif section.settings.image_step_4 != blank %}
            <img src="{{ section.settings.image_step_4 | image_url: width: 1920 }}" class="learn-moment-img" alt="" loading="lazy">
          {% else %}
            <div class="learn-moment-bg-fallback"></div>
          {% endif %}
          <div class="learn-moment-overlay"></div>
        </div>
        <div class="learn-moment-content">
          <h3 id="step-4-title" class="learn-moment-title">{{ section.settings.step4_title | default: 'VUELVE A MIRAR' }}</h3>
          <p class="learn-moment-text">{{ section.settings.step4_text | default: 'No es solo el vino.' }}</p>
          <p class="learn-moment-text">{{ section.settings.step4_text_2 | default: 'Es lo que empieza a aparecer.' }}</p>
        </div>
      </article>
    </section>

    <!-- BLOQUE 5 — MOMENTO / OJO -->
    <section id="mirada-momento" class="mirada-section mirada-momento" aria-labelledby="momento-title">
      <div class="mirada-block">
        <h2 id="momento-title" class="mirada-heading reveal">{{ section.settings.momento_title | default: 'MIRA EL MOMENTO' }}</h2>
        <p class="mirada-momento-text reveal delay-100">{{ section.settings.momento_text | default: 'No hay una forma correcta.' }}</p>
        <p class="mirada-momento-text reveal delay-200">{{ section.settings.momento_text_2 | default: 'Solo atención.' }}</p>
      </div>
    </section>

    <!-- BLOQUE 6 — INTERACCIÓN -->
    <section id="miradas-form" class="mirada-section mirada-archive" aria-labelledby="miradas-title">
      <div class="mirada-block">
        <h2 id="miradas-title" class="mirada-heading reveal">{{ section.settings.form_title | default: '¿Cómo lo ves ahora?' }}</h2>
        <form id="form-miradas" class="mirada-form reveal delay-100" novalidate>
          <fieldset class="mirada-fieldset">
            <legend class="sr-only">Elige una opción</legend>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="ligero" class="mirada-radio"> Ligero</label>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="intenso" class="mirada-radio"> Intenso</label>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="distinto" class="mirada-radio"> Distinto</label>
          </fieldset>
          <label class="mirada-textarea-label" for="tu-mirada">
            <span class="mirada-textarea-label-text">{{ section.settings.form_textarea_label | default: 'Tu mirada' }}</span>
            <textarea id="tu-mirada" name="tu_mirada" rows="2" placeholder="Opcional" class="mirada-textarea" aria-describedby="form-miradas-feedback"></textarea>
          </label>
          <div id="form-miradas-feedback" class="mirada-form-feedback" role="status" aria-live="polite"></div>
          <button type="submit" class="mirada-btn mirada-btn-primary w-full">{{ section.settings.form_submit | default: 'ENVIAR' }}</button>
        </form>
      </div>
    </section>

    <!-- BLOQUE 7 — CIERRE -->
    <section id="mirada-cta" class="mirada-section mirada-cta" aria-labelledby="cta-title">
      <div class="mirada-block mirada-cta-block">
        <h2 id="cta-title" class="sr-only">Cierre</h2>
        <p class="mirada-cta-text reveal">{{ section.settings.cta_text | default: 'El vino se descubre mirando.' }}</p>
        <a href="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}" class="mirada-btn mirada-btn-primary reveal delay-100">
          {{ section.settings.cta_label | default: 'VOLVER AL VINO' }}
        </a>
      </div>
    </section>
  </main>

  <footer class="mirada-footer">
    <a href="{{ routes.root_url }}">
      {% if settings.logo != blank %}
        <img src="{{ settings.logo | image_url: width: 300 }}" alt="Albino" class="mirada-footer-logo" width="150" height="60" loading="lazy">
      {% else %}
        <img data-bind-src="assets.logo" alt="Albino" class="mirada-footer-logo" width="150" height="60" loading="lazy">
      {% endif %}
    </a>
  </footer>
</div>

<script src="{{ 'mirada.js' | asset_url }}" defer></script>

