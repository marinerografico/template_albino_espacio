{% comment %}
  MIRADA — Experiencia NFC editorial para Albino.
  Mobile-first, premium, minimal. Dos modos: inmersivo y accesible.
  mirada.css se carga en el head (layout) para evitar FOUC en el hero.
{% endcomment %}

<div class="mirada-page mirada-page-root" id="mirada-page-root"
  data-audio-intro="{% if section.settings.audio_intro != blank %}{{ section.settings.audio_intro }}{% endif %}"
  data-audio-product="{% if section.settings.audio_product_info != blank %}{{ section.settings.audio_product_info }}{% endif %}"
  data-audio-nutrition="{% if section.settings.audio_nutrition != blank %}{{ section.settings.audio_nutrition }}{% endif %}"
  data-audio-discover="{% if section.settings.audio_discover != blank %}{{ section.settings.audio_discover }}{% endif %}"
  data-audio-learn-intro="{% if section.settings.audio_learn_intro != blank %}{{ section.settings.audio_learn_intro }}{% endif %}"
  data-audio-step-1="{% if section.settings.audio_step_1 != blank %}{{ section.settings.audio_step_1 }}{% endif %}"
  data-audio-step-2="{% if section.settings.audio_step_2 != blank %}{{ section.settings.audio_step_2 }}{% endif %}"
  data-audio-step-3="{% if section.settings.audio_step_3 != blank %}{{ section.settings.audio_step_3 }}{% endif %}"
  data-audio-step-4="{% if section.settings.audio_step_4 != blank %}{{ section.settings.audio_step_4 }}{% endif %}"
  data-audio-outro="{% if section.settings.audio_outro != blank %}{{ section.settings.audio_outro }}{% endif %}"
  data-product-url="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}">
  <div id="mirada-audio-band" class="mirada-audio-band" aria-live="polite" hidden>
    Audio activado
  </div>

  <main>
    <!-- 1. HERO / ENTRY -->
    <section id="mirada-hero" class="mirada-section mirada-hero" aria-labelledby="hero-title">
      <div class="mirada-hero-inner">
        <h1 id="hero-title" class="mirada-hero-title reveal">Etiqueta digital de Albino</h1>
        <p class="mirada-hero-intro reveal">Información del vino y una forma de mirarlo.</p>
        <div class="mirada-hero-actions">
          <a href="#product-info" class="mirada-btn mirada-btn-primary reveal delay-100">VER INFORMACIÓN DEL VINO</a>
          <button type="button" id="btn-accessible-hero" class="mirada-hero-skip reveal delay-200" aria-pressed="false" aria-label="Continuar en modo accesible">
            Continuar en modo accesible
          </button>
        </div>
      </div>
    </section>

    <!-- 2. PRODUCT INFORMATION -->
    <section id="product-info" class="mirada-section mirada-product" aria-labelledby="product-title">
      <div class="mirada-block">
        <h2 id="product-title" class="mirada-heading reveal">Información del vino</h2>
        <dl class="mirada-dl reveal delay-100">
          <div class="mirada-dl-row"><dt>Nombre</dt><dd>Albino</dd></div>
          <div class="mirada-dl-row"><dt>Tipo</dt><dd>Vino tinto dulce joven</dd></div>
          <div class="mirada-dl-row"><dt>Variedad</dt><dd>Tempranillo</dd></div>
          <div class="mirada-dl-row"><dt>Origen</dt><dd>Tierra de Barros · Extremadura</dd></div>
          <div class="mirada-dl-row"><dt>Alcohol</dt><dd>12,5 % vol</dd></div>
          <div class="mirada-dl-row"><dt>Formato</dt><dd>75 cl</dd></div>
          <div class="mirada-dl-row mirada-dl-row-last"><dt>Alérgenos</dt><dd>Contiene sulfitos</dd></div>
        </dl>
        <div class="mirada-product-actions reveal delay-200">
          <button type="button" id="btn-toggle-nutrition" class="mirada-btn mirada-btn-primary" aria-expanded="false" aria-controls="nutrition-info">
            Ver información nutricional
          </button>
          <a href="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}" class="mirada-btn mirada-btn-secondary">
            Ver botella
          </a>
          <button type="button" id="btn-audio-product" class="mirada-btn mirada-btn-audio" aria-label="Escuchar información del vino" hidden>
            Escuchar
          </button>
        </div>
      </div>
    </section>

    <!-- 3. NUTRITION INFORMATION -->
    <section id="nutrition-info" class="mirada-section mirada-nutrition" aria-labelledby="nutrition-title" hidden>
      <div class="mirada-block mirada-nutrition-block">
        <h2 id="nutrition-title" class="mirada-nutrition-header reveal">Información nutricional – Valores por 100 ml</h2>
        <table class="mirada-table reveal delay-100" role="table" aria-describedby="nutrition-title">
          <caption class="sr-only">Valores nutricionales por 100 ml de vino Albino</caption>
          <tbody>
            <tr><td>Energía</td><td>350 kJ / 85 kcal</td></tr>
            <tr><td>Carbohidratos</td><td>4 g</td></tr>
            <tr class="mirada-table-sub"><td>de los cuales azúcares</td><td>4 g</td></tr>
            <tr><td>Grasas</td><td>0 g</td></tr>
            <tr><td>Proteínas</td><td>0 g</td></tr>
            <tr><td>Sal</td><td>0 g</td></tr>
          </tbody>
        </table>
        <p class="mirada-nutrition-note reveal delay-200">Consumir con responsabilidad.</p>
      </div>
    </section>

    <!-- 4. DESCUBRIR EL VINO -->
    <section id="discover-wine" class="mirada-section mirada-discover" aria-labelledby="discover-title">
      <div class="mirada-block mirada-discover-block">
        <p id="discover-title" class="mirada-discover-single reveal">Un vino de Tierra de Barros.</p>
      </div>
    </section>

    <!-- 5. APRENDER A MIRARLO -->
    <section id="learn-to-look" class="mirada-learn" aria-labelledby="learn-title">
      <div class="mirada-learn-intro reveal" id="learn-intro">
        <h2 id="learn-title" class="mirada-heading">No es una cata.</h2>
        <button type="button" id="btn-audio-learn" class="mirada-btn mirada-btn-audio" aria-label="Escuchar recorrido guiado de los 4 momentos" hidden>
          Escuchar recorrido
        </button>
      </div>

      <article id="step-1" class="learn-moment learn-moment-clean" aria-labelledby="step-1-title" data-step="1">
        <div class="learn-moment-content">
          <p class="learn-moment-num" aria-hidden="true">01</p>
          <h3 id="step-1-title" class="learn-moment-title">MIRA</h3>
          <p class="learn-moment-text">Despacio.</p>
        </div>
      </article>

      <article id="step-2" class="learn-moment learn-moment-media" aria-labelledby="step-2-title" data-step="2">
        <div class="learn-moment-bg" aria-hidden="true">
          {% if section.settings.video_step_2 != blank %}
            <video class="learn-moment-video" autoplay muted loop playsinline aria-hidden="true">
              <source src="{{ section.settings.video_step_2 | escape }}" type="video/mp4">
            </video>
          {% else %}
            <div class="learn-moment-bg-fallback"></div>
          {% endif %}
          <div class="learn-moment-overlay"></div>
        </div>
        <div class="learn-moment-content">
          <p class="learn-moment-num" aria-hidden="true">02</p>
          <h3 id="step-2-title" class="learn-moment-title">ACÉRCATE</h3>
          <p class="learn-moment-text">Sin buscar.</p>
        </div>
      </article>

      <article id="step-3" class="learn-moment learn-moment-clean" aria-labelledby="step-3-title" data-step="3">
        <div class="learn-moment-content">
          <p class="learn-moment-num" aria-hidden="true">03</p>
          <h3 id="step-3-title" class="learn-moment-title">PRUEBA</h3>
          <p class="learn-moment-text">Sin prisa.</p>
        </div>
      </article>

      <article id="step-4" class="learn-moment learn-moment-media" aria-labelledby="step-4-title" data-step="4">
        <div class="learn-moment-bg" aria-hidden="true">
          {% if section.settings.video_step_4 != blank %}
            <video class="learn-moment-video" autoplay muted loop playsinline aria-hidden="true">
              <source src="{{ section.settings.video_step_4 | escape }}" type="video/mp4">
            </video>
          {% else %}
            <div class="learn-moment-bg-fallback"></div>
          {% endif %}
          <div class="learn-moment-overlay"></div>
        </div>
        <div class="learn-moment-content">
          <p class="learn-moment-num" aria-hidden="true">04</p>
          <h3 id="step-4-title" class="learn-moment-title">VUELVE A MIRAR</h3>
          <p class="learn-moment-text">Otra vez.</p>
        </div>
      </article>
    </section>

    <!-- 5. MIRA EL MOMENTO -->
    <section id="mirada-momento" class="mirada-section mirada-momento" aria-labelledby="momento-title">
      <div class="mirada-block">
        <h2 id="momento-title" class="mirada-heading reveal">MIRA EL MOMENTO</h2>
        <p class="mirada-momento-text reveal delay-100">Solo atención.</p>
      </div>
    </section>

    <!-- 6. ARCHIVO DE MIRADAS -->
    <section id="miradas-form" class="mirada-section mirada-archive" aria-labelledby="miradas-title">
      <div class="mirada-block">
        <h2 id="miradas-title" class="mirada-heading reveal">¿Cómo lo ves?</h2>
        <form id="form-miradas" class="mirada-form reveal delay-100" novalidate>
          <fieldset class="mirada-fieldset">
            <legend class="sr-only">Elige una opción</legend>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="ligero" class="mirada-radio"> Ligero</label>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="intenso" class="mirada-radio"> Intenso</label>
            <label class="mirada-radio-label"><input type="radio" name="mirada" value="distinto" class="mirada-radio"> Distinto</label>
          </fieldset>
          <label class="mirada-textarea-label" for="tu-mirada">
            <span class="mirada-textarea-label-text">Tu mirada</span>
            <textarea id="tu-mirada" name="tu_mirada" rows="2" placeholder="Opcional" class="mirada-textarea" aria-describedby="form-miradas-feedback"></textarea>
          </label>
          <div id="form-miradas-feedback" class="mirada-form-feedback" role="status" aria-live="polite" aria-atomic="true"></div>
          <button type="submit" class="mirada-btn mirada-btn-primary w-full">ENVIAR</button>
        </form>
      </div>
    </section>

    <!-- 7. CTA FINAL -->
    <section id="mirada-cta" class="mirada-section mirada-cta" aria-labelledby="cta-title">
      <div class="mirada-block mirada-cta-block">
        <h2 id="cta-title" class="sr-only">Cierre</h2>
        <div class="mirada-cta-actions">
          <a href="{{ section.settings.product_url | default: routes.root_url | append: 'products/albino-edicion-2026' }}" class="mirada-btn mirada-btn-primary">VOLVER AL VINO</a>
        </div>
      </div>
    </section>
  </main>

  <button type="button" id="btn-accessible-toggle" class="mirada-accessible-tag" aria-pressed="false" aria-label="Usar modo accesible">Modo accesible</button>
  <footer class="mirada-footer">
    <a href="{{ routes.root_url }}">
      {% if settings.logo != blank %}
        <img src="{{ settings.logo | image_url: width: 300 }}" alt="Logotipo de Albino, vino de Tierra de Barros" class="mirada-footer-logo" width="150" height="60" loading="lazy">
      {% else %}
        <img data-bind-src="assets.logo" alt="Logotipo de Albino, vino de Tierra de Barros" class="mirada-footer-logo" width="150" height="60" loading="lazy">
      {% endif %}
    </a>
  </footer>
</div>

<audio id="mirada-audio-player" preload="metadata" aria-hidden="true"></audio>

<script src="{{ 'mirada.js' | asset_url }}" defer></script>

