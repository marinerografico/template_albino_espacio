      "info": "URL del MP4 (Content → Files)"
    },
    {
      "type": "text",
      "id": "video_step_2",
      "label": "Vídeo paso 2 — Acércate al vino"
    },
    {
      "type": "text",
      "id": "video_step_3",
      "label": "Vídeo paso 3 — Prueba"
    },
    {
      "type": "text",
      "id": "video_step_4",
      "label": "Vídeo paso 4 — Vuelve a mirar"
    },
    {
      "type": "header",
      "content": "Audios — flujo completo"
    },
    {
      "type": "text",
      "id": "audio_intro",
      "label": "Audio intro — Hero (al activar experiencia sonora)",
      "info": "URL del MP3 (Content → Files)"
    },
    {
      "type": "text",
      "id": "audio_product_info",
      "label": "Audio — Información del vino"
    },
    {
      "type": "text",
      "id": "audio_nutrition",
      "label": "Audio — Información nutricional"
    },
    {
      "type": "text",
      "id": "audio_discover",
      "label": "Audio — Descubrir el vino"
    },
    {
      "type": "text",
      "id": "audio_learn_intro",
      "label": "Audio — Intro Aprender a mirarlo"
    },
    {
      "type": "text",
      "id": "audio_step_1",
      "label": "Audio paso 1 — Mira el momento"
    },
    {
      "type": "text",
      "id": "audio_step_2",
